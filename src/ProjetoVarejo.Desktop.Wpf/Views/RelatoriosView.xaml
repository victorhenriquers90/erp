<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Command="{Binding CarregarCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Height="40">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Atualizar" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <StackPanel>
                <TextBlock Text="Relatorios" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="Vendas, produtos e desempenho" Style="{StaticResource SectionSubtitleStyle}"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Padding="20" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="TOTAL VENDIDO NO PERIODO"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource AppTextMediumBrush}"/>
                <TextBlock Text="{Binding TotalVendido, StringFormat=C2}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource AppTextDarkBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Vendas por dia"
                               FontWeight="SemiBold" FontSize="14" Margin="16,14,16,10"/>
                    <DataGrid ItemsSource="{Binding VendasPorDia}"
                              Style="{StaticResource Win11DataGridStyle}"
                              IsReadOnly="True" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dia"   Binding="{Binding Data, StringFormat=dd/MM/yyyy}"  Width="130"/>
                            <DataGridTextColumn Header="Qtd"   Binding="{Binding Quantidade}"                     Width="90"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C2}"         Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Top produtos"
                               FontWeight="SemiBold" FontSize="14" Margin="16,14,16,10"/>
                    <DataGrid ItemsSource="{Binding TopProdutos}"
                              Style="{StaticResource Win11DataGridStyle}"
                              IsReadOnly="True" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codigo"  Binding="{Binding Codigo}"                                 Width="100"/>
                            <DataGridTextColumn Header="Produto" Binding="{Binding Descricao}"                              Width="*"/>
                            <DataGridTextColumn Header="Qtd"     Binding="{Binding QuantidadeVendida, StringFormat=N3}"     Width="90"/>
                            <DataGridTextColumn Header="Total"   Binding="{Binding TotalVendido, StringFormat=C2}"          Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
