<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.EstoqueWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Movimentações de entrada/saída e alertas de estoque mínimo."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,14">
            <Button Content="Lançar entrada"
                    Width="170"
                    Height="40"
                    Background="#1F9D55"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Entrada_Click" />
            <Button Content="Ajustar saída"
                    Margin="10,0,0,0"
                    Width="170"
                    Height="40"
                    Background="#D64545"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Saida_Click" />
        </StackPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="Movimentações">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Card3DStyle}"
                            Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="De" FontWeight="SemiBold" />
                                <DatePicker x:Name="DtDe" Width="140" SelectedDateChanged="FiltroDataMudou" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Até" FontWeight="SemiBold" />
                                <DatePicker x:Name="DtAte" Width="140" SelectedDateChanged="FiltroDataMudou" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="Produto" FontWeight="SemiBold" />
                                <TextBox x:Name="TxtFiltroProduto"
                                         Height="36"
                                         VerticalContentAlignment="Center"
                                         Padding="10,0"
                                         TextChanged="FiltroTextoMudou" />
                            </StackPanel>
                            <Button Grid.Column="3"
                                    Margin="12,20,0,0"
                                    Width="110"
                                    Height="36"
                                    Content="Atualizar"
                                    Click="AtualizarMov_Click" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Style="{StaticResource Card3DStyle}"
                            Padding="8">
                        <DataGrid x:Name="DgMovimentos"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="1.5*" />
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="1.4*" />
                                <DataGridTextColumn Header="Produto" Binding="{Binding Produto}" Width="2.8*" />
                                <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="1*" />
                                <DataGridTextColumn Header="Saldo Anterior" Binding="{Binding SaldoAnterior}" Width="1.3*" />
                                <DataGridTextColumn Header="Saldo Atual" Binding="{Binding SaldoAtual}" Width="1.3*" />
                                <DataGridTextColumn Header="Documento" Binding="{Binding Documento}" Width="1.8*" />
                                <DataGridTextColumn Header="Usuário" Binding="{Binding Usuario}" Width="1.4*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Abaixo do mínimo">
                <Border Margin="0,10,0,0"
                        Style="{StaticResource Card3DStyle}"
                        Padding="8">
                    <DataGrid x:Name="DgMinimo"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="1.2*" />
                            <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="3*" />
                            <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque}" Width="1.4*" />
                            <DataGridTextColumn Header="Mínimo" Binding="{Binding Minimo}" Width="1.4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
