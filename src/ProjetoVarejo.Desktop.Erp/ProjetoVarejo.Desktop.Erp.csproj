    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyTitle>PROJETO ERP</AssemblyTitle>
  </PropertyGroup>

  <ItemGroup>
