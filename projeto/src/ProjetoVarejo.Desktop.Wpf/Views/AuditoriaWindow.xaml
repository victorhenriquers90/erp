<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.AuditoriaWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Trilha de alterações e autorizações de supervisor."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,12"
                Style="{StaticResource Card3DStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="De" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtDe" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Até" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtAte" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Entidade" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtEntidade" Height="36" VerticalContentAlignment="Center" Padding="10,0" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="10,0,0,0">
                    <TextBlock Text="Usuário (nome/login)" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtUsuario" Height="36" VerticalContentAlignment="Center" Padding="10,0" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="10,20,0,0">
                    <CheckBox x:Name="ChkSomenteSupervisorPdv"
                              Content="Somente autorizações de supervisor no PDV"
                              IsChecked="True" />
                </StackPanel>
                <Button Grid.Column="5"
                        Margin="10,20,0,0"
                        Width="120"
                        Height="36"
                        Content="Filtrar"
                        Click="Filtrar_Click" />
                <Button Grid.Column="6"
                        Margin="10,20,0,0"
                        Width="170"
                        Height="36"
                        Content="Ver detalhes JSON"
                        Click="VerDetalhes_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource Card3DStyle}"
                Padding="8">
            <DataGrid x:Name="DgAuditoria"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      MouseDoubleClick="DgAuditoria_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="1.4*" />
                    <DataGridTextColumn Header="Usuário" Binding="{Binding Usuario}" Width="1.8*" />
                    <DataGridTextColumn Header="Entidade" Binding="{Binding Entidade}" Width="1.6*" />
                    <DataGridTextColumn Header="Registro" Binding="{Binding Registro}" Width="1*" />
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="1*" />
                    <DataGridTextColumn Header="Resumo" Binding="{Binding Resumo}" Width="3.4*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
