<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="PROJETO NEGOCIOS ERP"
        Height="620" Width="1060"
        MinHeight="620" MinWidth="1060"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#070F1C"
        FontFamily="Segoe UI">

    <Grid>

        <!-- ═══ CAMADA 1: Gradiente base ═══════════════════════════ -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#060D1A" Offset="0"/>
                    <GradientStop Color="#0A1628" Offset="0.5"/>
                    <GradientStop Color="#0C1830" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ═══ CAMADA 2: Malha de pontos ═══════════════════════════ -->
        <Rectangle IsHitTestVisible="False">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              ViewportUnits="Absolute"
                              Viewport="0,0,30,30">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#FFFFFF0D">
                            <GeometryDrawing.Geometry>
                                <EllipseGeometry Center="15,15" RadiusX="1.1" RadiusY="1.1"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ═══ CAMADA 3: Decoração — blob topo-esquerdo ═══════════ -->
        <Ellipse Width="420" Height="420"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-180,-180,0,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#1A3060" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ═══ CAMADA 4: Anéis geométricos — baixo-direito ════════ -->
        <Canvas HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Width="560" Height="560"
                Margin="0,0,-200,-200"
                IsHitTestVisible="False"
                ClipToBounds="False">
            <!-- Anel exterior -->
            <Ellipse Canvas.Left="0" Canvas.Top="0"
                     Width="560" Height="560"
                     Stroke="#FFFFFF" StrokeThickness="0.6"
                     Fill="Transparent" Opacity="0.04"/>
            <!-- Anel médio âmbar -->
            <Ellipse Canvas.Left="90" Canvas.Top="90"
                     Width="380" Height="380"
                     Stroke="#C47412" StrokeThickness="1.2"
                     Fill="Transparent" Opacity="0.18"/>
            <!-- Anel interno -->
            <Ellipse Canvas.Left="175" Canvas.Top="175"
                     Width="210" Height="210"
                     Stroke="#FFFFFF" StrokeThickness="0.5"
                     Fill="Transparent" Opacity="0.06"/>
            <!-- Ponto âmbar no anel médio (topo) -->
            <Ellipse Canvas.Left="274" Canvas.Top="87"
                     Width="12" Height="12"
                     Fill="#C47412" Opacity="0.85"/>
            <!-- Ponto branco lateral -->
            <Ellipse Canvas.Left="468" Canvas.Top="218"
                     Width="7" Height="7"
                     Fill="#FFFFFF" Opacity="0.25"/>
            <!-- Tracejado de setor (linha industrial) -->
            <Path Stroke="#C47412" StrokeThickness="1" Opacity="0.2"
                  Data="M 280,90 L 280,280 L 90,280"/>
        </Canvas>

        <!-- ═══ CAMADA 5: Acento âmbar no canto superior direito ═══ -->
        <Ellipse Width="200" Height="200"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-100,-80,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#C4741220" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ═══ CONTEÚDO PRINCIPAL ═══════════════════════════════════ -->
        <Grid Margin="60,0,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Branding -->
                <ColumnDefinition Width="430"/>
                <!-- Form card -->
            </Grid.ColumnDefinitions>

            <!-- ────── COLUNA ESQUERDA: Branding ─────────────────── -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,40,0">

                <!-- Badge ERP -->
                <Border CornerRadius="6"
                        Background="#C4741218"
                        BorderBrush="#C4741255"
                        BorderThickness="1"
                        Padding="12,5"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,22">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Engine24" FontSize="12"
                                       Foreground="#C47412" Margin="0,0,6,0"/>
                        <TextBlock Text="SISTEMA ERP · MANUFATURA"
                                   Foreground="#C47412"
                                   FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Ícone principal com glow -->
                <Border Width="80" Height="80"
                        CornerRadius="22"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,22">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D4841A" Offset="0"/>
                            <GradientStop Color="#A85F0A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#C47412" BlurRadius="28"
                                          ShadowDepth="0" Opacity="0.55"/>
                    </Border.Effect>
                    <ui:SymbolIcon Symbol="BuildingFactory24" FontSize="38"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <!-- Nome do sistema -->
                <TextBlock Text="PROJETO"
                           FontSize="40" FontWeight="Bold"
                           Foreground="White"
                           LineHeight="44"/>
                <TextBlock Text="NEGOCIOS"
                           FontSize="40" FontWeight="Bold"
                           LineHeight="44"
                           Margin="0,-4,0,0">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#E8921E" Offset="0"/>
                            <GradientStop Color="#C47412" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="Gestao integrada para industria e varejo"
                           Foreground="#3D607A"
                           FontSize="13"
                           Margin="0,10,0,0"/>

                <!-- Divisor com destaque -->
                <Grid Margin="0,30,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Height="2" VerticalAlignment="Center"
                                Fill="#C47412" Opacity="0.8"/>
                    <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center"
                                Margin="8,0,0,0" Fill="#1A3050"/>
                </Grid>

                <!-- Features com ícone-badge -->
                <StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="#0E1E30" Margin="0,0,14,0">
                            <ui:SymbolIcon Symbol="Production24" FontSize="17"
                                           Foreground="#C47412"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Producao e Estoque"
                                       Foreground="#C8D8E4" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Controle total do chao de fabrica"
                                       Foreground="#2E4A5C" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="#0E1E30" Margin="0,0,14,0">
                            <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="17"
                                           Foreground="#C47412"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Financeiro e Fiscal"
                                       Foreground="#C8D8E4" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="NFC-e, contas e fluxo de caixa"
                                       Foreground="#2E4A5C" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10"
                                Background="#0E1E30" Margin="0,0,14,0">
                            <ui:SymbolIcon Symbol="WrenchScrewdriver24" FontSize="17"
                                           Foreground="#C47412"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Operacoes e Cadeia"
                                       Foreground="#C8D8E4" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Compras, fornecedores e logistica"
                                       Foreground="#2E4A5C" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <!-- Versão -->
                <StackPanel Orientation="Horizontal" Margin="0,36,0,0">
                    <Ellipse Width="6" Height="6" Fill="#C47412"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="v1.0.0  ·  2026  ·  Build Debug"
                               Foreground="#1E3448" FontSize="11"/>
                </StackPanel>

            </StackPanel>

            <!-- ────── COLUNA DIREITA: Card flutuante ─────────────── -->
            <Border Grid.Column="1"
                    Margin="0,28,0,28"
                    CornerRadius="20"
                    Background="White">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="60"
                                      ShadowDepth="16" Opacity="0.45"/>
                </Border.Effect>

                <Grid>
                    <!-- Linha de acento no topo do card -->
                    <Rectangle VerticalAlignment="Top" Height="3"
                                HorizontalAlignment="Stretch"
                                RadiusX="20" RadiusY="20">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#C47412" Offset="0"/>
                                <GradientStop Color="#E8921E" Offset="0.5"/>
                                <GradientStop Color="#C47412" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Conteúdo do formulário -->
                    <StackPanel VerticalAlignment="Center" Margin="42,52,42,46">

                        <!-- Cabeçalho do formulário -->
                        <StackPanel Margin="0,0,0,28">
                            <TextBlock Text="Acessar o sistema"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="#101820"/>
                            <TextBlock Text="Entre com suas credenciais para continuar"
                                       FontSize="12" Foreground="#90A0AE"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- ── Campo: Usuário ── -->
                        <TextBlock Text="USUARIO"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#B0BCC8"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <TextBox x:Name="TxtLogin"
                                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                     Height="44"
                                     Padding="40,0,12,0"
                                     VerticalContentAlignment="Center"
                                     Style="{StaticResource Win11TextBoxStyle}"/>
                            <Border Width="1" Background="#EBEBEB"
                                    HorizontalAlignment="Left" Margin="36,8,0,8"/>
                            <ui:SymbolIcon Symbol="Person24" FontSize="15"
                                           Foreground="#B8C4CC"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="11,0,0,0"
                                           IsHitTestVisible="False"/>
                        </Grid>

                        <!-- ── Campo: Senha ── -->
                        <TextBlock Text="SENHA"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#B0BCC8"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <PasswordBox x:Name="TxtSenha"
                                         Height="44"
                                         Padding="40,0,12,0"
                                         Style="{StaticResource Win11PasswordBoxStyle}"
                                         KeyDown="TxtSenha_KeyDown"/>
                            <Border Width="1" Background="#EBEBEB"
                                    HorizontalAlignment="Left" Margin="36,8,0,8"/>
                            <ui:SymbolIcon Symbol="Lock24" FontSize="15"
                                           Foreground="#B8C4CC"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="11,0,0,0"
                                           IsHitTestVisible="False"/>
                        </Grid>

                        <!-- ── Erro ── -->
                        <Border x:Name="PnlErro"
                                Visibility="Collapsed"
                                Margin="0,14,0,0"
                                Background="#FEF2F2"
                                CornerRadius="10"
                                BorderBrush="#FECACA"
                                BorderThickness="1"
                                Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="15"
                                               Foreground="#DC2626"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtErro"
                                           TextWrapping="Wrap"
                                           Foreground="#991B1B"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Botão de acesso ── -->
                        <Button x:Name="BtnEntrar"
                                Height="48"
                                Margin="0,20,0,0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="BtnEntrar_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowRight24" FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               Foreground="White"/>
                                <TextBlock Text="Entrar no sistema"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ── Barra de progresso ── -->
                        <ProgressBar x:Name="PbLoading"
                                     Visibility="Collapsed"
                                     Margin="0,12,0,0"
                                     Height="2"
                                     IsIndeterminate="True"
                                     Foreground="{StaticResource AppPrimaryBrush}"
                                     Background="#F3F4F6"/>

                    </StackPanel>

                    <!-- Rodapé do card -->
                    <StackPanel VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Margin="0,0,0,18">
                        <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="11"
                                       Foreground="#D0D8E0" Margin="0,0,5,0"/>
                        <TextBlock Text="Conexao criptografada e monitorada"
                                   FontSize="11" Foreground="#D0D8E0"/>
                    </StackPanel>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
