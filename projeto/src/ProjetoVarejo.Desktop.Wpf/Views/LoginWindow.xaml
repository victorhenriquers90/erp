<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projeto ERP - Acesso"
        Height="680"
        Width="1180"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BrandGradient}">
            <Grid Margin="56,48">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" Background="{StaticResource Primary}" CornerRadius="10">
                        <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Projeto ERP" Foreground="White" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="ENTERPRISE" Foreground="#8FB0D6" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <Grid SnapsToDevicePixels="True">
                        <TextBlock Text="GEST&#xC3;O ESTRAT&#xC9;GICA PARA O SEU NEG&#xD3;CIO"
                                   Margin="1,1,0,0"
                                   Foreground="#2E4E7096"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType" />
                        <TextBlock Text="GEST&#xC3;O ESTRAT&#xC9;GICA PARA O SEU NEG&#xD3;CIO"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType" />
                    </Grid>
                    <TextBlock Text="Planejamento, estoque, financeiro e fiscal (NFC-e) em um so lugar."
                               Foreground="#A9C3E0"
                               FontSize="14"
                               Margin="0,14,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="&#xA9; 2026 Projeto ERP &#xB7; Versao 1.0.0"
                           Foreground="#6E8CAE"
                           FontSize="11" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BgCard}">
            <StackPanel Width="320" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Bem-vindo de volta" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextStrong}" />
                <TextBlock Text="Entre com suas credenciais para acessar o sistema."
                           FontSize="13" Foreground="{StaticResource TextSoft}" Margin="0,6,0,0" TextWrapping="Wrap" />

                <TextBlock Text="USUARIO" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSoft}" Margin="0,28,0,6" />
                <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgInput}" Height="46">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource Primary}" />
                        <TextBox Grid.Column="1" x:Name="TxtLogin" BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" FontSize="14" Text="admin" />
                    </Grid>
                </Border>

                <TextBlock Text="SENHA" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSoft}" Margin="0,16,0,6" />
                <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgInput}" Height="46">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource Primary}" />
                        <PasswordBox Grid.Column="1" x:Name="TxtSenha" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="14" Password="admin" />
                    </Grid>
                </Border>

                <Button x:Name="BtnEntrar"
                        Margin="0,18,0,0"
                        Height="48"
                        Content="Entrar"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Entrar_Click" />

                <Border x:Name="ErroBox" Margin="0,16,0,0" Background="#FEF2F2" BorderBrush="#FCA5A5"
                        BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Foreground="#B42318" FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0" />
                        <TextBlock x:Name="LblErro" Foreground="#B42318" FontSize="12" TextWrapping="Wrap" MaxWidth="260" />
                    </StackPanel>
                </Border>

                <Button Content="Sair do sistema"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource TextSoft}"
                        FontSize="12"
                        Cursor="Hand"
                        Click="Sair_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
