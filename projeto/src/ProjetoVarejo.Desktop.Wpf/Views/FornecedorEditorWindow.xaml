<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.FornecedorEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fornecedor"
        Height="680"
        Width="920"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.ColumnSpan="2"
                               Text="Cadastro de fornecedor"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextStrong}" />

                    <StackPanel Grid.Row="1" Margin="0,14,8,0">
                        <TextBlock Text="Razão social" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtRazaoSocial" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,14,0,0">
                        <TextBlock Text="Nome fantasia" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtNomeFantasia" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,10,8,0">
                        <TextBlock Text="CNPJ" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtCnpj" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Telefone" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtTelefone" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,10,8,0">
                        <TextBlock Text="Email" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtEmail" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Contato" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtContato" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,10,8,0">
                        <TextBlock Text="Cidade" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtCidade" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="UF" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtUf" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <TextBlock Text="Observação" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtObservacao"
                                 Height="92"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 Padding="10,8" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <CheckBox x:Name="ChkAtivo"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Content="Fornecedor ativo" />
            <Button Content="Cancelar"
                    Width="112"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click" />
            <Button x:Name="BtnSalvar"
                    Content="Salvar"
                    Width="130"
                    Height="40"
                    Background="{StaticResource Primary}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Salvar_Click" />
        </StackPanel>
    </Grid>
</Window>
