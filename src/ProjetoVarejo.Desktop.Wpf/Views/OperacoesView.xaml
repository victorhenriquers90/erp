<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.OperacoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Operacoes de loja" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Rotinas internas para fechamento, producao, backup e implantacao" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Modulos}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <md:Card Width="300" Height="158" Margin="0,0,16,16" Padding="18"
                             UniformCornerRadius="14" md:ElevationAssist.Elevation="Dp2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="40" Height="40" CornerRadius="12" Background="#EAF5FF">
                                    <md:PackIcon Kind="{Binding Icone}" Foreground="#1674B8" Width="22" Height="22"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Nome}" FontSize="16" FontWeight="SemiBold"
                                           Margin="12,8,0,0" Foreground="{StaticResource AppTextDarkBrush}"/>
                            </DockPanel>
                            <TextBlock Grid.Row="1" Text="{Binding Descricao}" TextWrapping="Wrap"
                                       Margin="0,14,0,0" Foreground="{StaticResource AppTextMediumBrush}"/>
                            <Border Grid.Row="2" HorizontalAlignment="Left" CornerRadius="10" Background="#E8F5EC" Padding="10,5">
                                <TextBlock Text="{Binding Status}" Foreground="#14823B" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </md:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
