<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.CaixaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Caixa" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Status}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>
        <md:Card Grid.Row="1" Padding="24" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp1" MaxWidth="560" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Abertura de caixa" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                <TextBox Text="{Binding ValorAbertura, UpdateSourceTrigger=PropertyChanged}"
                         md:HintAssist.Hint="Valor de abertura"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="48"/>
                <Button Command="{Binding AbrirCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource AppPrimaryBrush}"
                        Foreground="White"
                        Height="44"
                        Margin="0,16,0,0"
                        md:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="CashRegister" Width="18" Height="18"/>
                        <TextBlock Text="Abrir caixa" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Erro}" Foreground="{StaticResource AppErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
            </StackPanel>
        </md:Card>
    </Grid>
</UserControl>
