<Window x:Class="ProjetoVarejo.DesktopShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ProjetoVarejo"
        Width="1280"
        Height="780"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ShellBackground}">
    <Grid>
        <wv2:WebView2 x:Name="Browser"
                      Visibility="Collapsed" />

        <Border x:Name="LoadingPanel"
                Background="{StaticResource ShellBackground}">
            <Grid>
                <Border Width="520"
                        Padding="32"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="White"
                        CornerRadius="20"
                        BorderThickness="1"
                        BorderBrush="#E2E8F0">
                    <Border.Effect>
                        <DropShadowEffect Color="#334155"
                                          BlurRadius="32"
                                          ShadowDepth="8"
                                          Opacity="0.16" />
                    </Border.Effect>

                    <StackPanel>
                        <Grid Width="72"
                              Height="72"
                              HorizontalAlignment="Left">
                            <Ellipse Fill="#FFF4E5" />
                            <TextBlock Text="PV"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ShellAccent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="ProjetoVarejo"
                                   Margin="0,22,0,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ShellText}" />

                        <TextBlock Text="Preparando o sistema desktop..."
                                   Margin="0,8,0,0"
                                   FontSize="15"
                                   Foreground="{StaticResource ShellMuted}" />

                        <ProgressBar Margin="0,28,0,0"
                                     Height="8"
                                     IsIndeterminate="True"
                                     Foreground="{StaticResource ShellAccent}" />

                        <TextBlock x:Name="StatusText"
                                   Margin="0,18,0,0"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource ShellMuted}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
