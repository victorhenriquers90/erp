<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.ValorPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Valor"
        Height="300"
        Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card3DStyle}" Padding="16">
            <StackPanel>
                <TextBlock x:Name="LblTitulo"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />
                <TextBlock x:Name="LblCampo"
                           Margin="0,12,0,4"
                           FontWeight="SemiBold" />
                <TextBox x:Name="TxtValor"
                         Height="40"
                         VerticalContentAlignment="Center"
                         Padding="10,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Height="38" Margin="0,0,10,0" Click="Cancelar_Click" />
            <Button Content="Confirmar" Width="120" Height="38" Background="{StaticResource Primary}" Foreground="White" BorderThickness="0" Click="Confirmar_Click" />
        </StackPanel>
    </Grid>
</Window>
