<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.EstoqueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Command="{Binding CarregarCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Height="40">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Atualizar" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <StackPanel>
                <TextBlock Text="Estoque" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="{Binding Resumo}" Style="{StaticResource SectionSubtitleStyle}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Abaixo do minimo"
                               FontWeight="SemiBold" FontSize="14" Margin="16,14,16,10"/>
                    <DataGrid ItemsSource="{Binding Alertas}"
                              Style="{StaticResource Win11DataGridStyle}"
                              IsReadOnly="True" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Codigo"  Binding="{Binding Codigo}"                    Width="90"/>
                            <DataGridTextColumn Header="Produto" Binding="{Binding Descricao}"                 Width="*"/>
                            <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque, StringFormat=N3}"  Width="100"/>
                            <DataGridTextColumn Header="Minimo"  Binding="{Binding EstoqueMinimo, StringFormat=N3}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Movimentos recentes"
                               FontWeight="SemiBold" FontSize="14" Margin="16,14,16,10"/>
                    <DataGrid ItemsSource="{Binding Movimentos}"
                              Style="{StaticResource Win11DataGridStyle}"
                              IsReadOnly="True" BorderThickness="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data"    Binding="{Binding CriadoEm, StringFormat=dd/MM HH:mm}" Width="110"/>
                            <DataGridTextColumn Header="Tipo"    Binding="{Binding Tipo}"                               Width="120"/>
                            <DataGridTextColumn Header="Produto" Binding="{Binding Produto.Descricao}"                  Width="*"/>
                            <DataGridTextColumn Header="Qtd"     Binding="{Binding Quantidade, StringFormat=N3}"        Width="90"/>
                            <DataGridTextColumn Header="Saldo"   Binding="{Binding SaldoAtual, StringFormat=N3}"        Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
