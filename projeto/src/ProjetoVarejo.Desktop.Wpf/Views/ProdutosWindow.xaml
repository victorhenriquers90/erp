<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.ProdutosWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="LblResumo"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card3DStyle}" Margin="0,16,0,16" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Busca com lupa -->
                <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8"
                        Background="{StaticResource BgInput}" Height="40" Width="360" HorizontalAlignment="Left">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource TextSoft}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="TxtBusca" BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" FontSize="14"
                                 TextChanged="TxtBusca_TextChanged" />
                    </Grid>
                </Border>

                <Button Grid.Column="1" Margin="10,0,0,0" Width="120" Height="40"
                        Style="{StaticResource PrimaryButtonStyle}" Click="Novo_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Novo" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Margin="8,0,0,0" Width="110" Height="40" Click="Editar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Editar" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Margin="8,0,0,0" Width="110" Height="40" Click="Excluir_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Excluir" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="4" Margin="8,0,0,0" Width="44" Height="40" Click="Atualizar_Click" ToolTip="Atualizar">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <DataGrid x:Name="DgProdutos"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="1.2*" />
                    <DataGridTextColumn Header="Código de barras" Binding="{Binding CodigoBarras}" Width="1.8*" />
                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="3*" />
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="1.8*" />
                    <DataGridTextColumn Header="Un" Binding="{Binding Unidade}" Width="0.8*" />
                    <DataGridTextColumn Header="Preço" Binding="{Binding PrecoVenda}" Width="1.2*" />
                    <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque}" Width="1.2*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
