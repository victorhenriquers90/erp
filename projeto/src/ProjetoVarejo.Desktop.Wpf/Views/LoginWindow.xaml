<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjetoVarejo ERP - Acesso"
        Height="640"
        Width="980"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- ══════ PAINEL DE MARCA ══════ -->
        <Border Grid.Column="0" Background="{StaticResource BrandGradient}">
            <Grid Margin="56,48">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" Background="{StaticResource Primary}" CornerRadius="10" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ProjetoVarejo" Foreground="White" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="ENTERPRISE" Foreground="#8FB0D6" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <!-- Tagline + features -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="Gestão completa do seu varejo."
                               Foreground="White" FontSize="30" FontWeight="Light" TextWrapping="Wrap" LineHeight="40" />
                    <TextBlock Text="PDV, estoque, financeiro e fiscal (NFC-e) em um só lugar."
                               Foreground="#A9C3E0" FontSize="14" Margin="0,14,0,0" TextWrapping="Wrap" />

                    <StackPanel Margin="0,36,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#5B9BD5" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Emissão de NFC-e integrada à SEFAZ-SP" Foreground="#D6E3F2" FontSize="13" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#5B9BD5" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Controle de estoque em tempo real" Foreground="#D6E3F2" FontSize="13" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#5B9BD5" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Rede local: servidor + múltiplos caixas" Foreground="#D6E3F2" FontSize="13" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="© 2026 ProjetoVarejo · Versão 1.0.0"
                           Foreground="#6E8CAE" FontSize="11" />
            </Grid>
        </Border>

        <!-- ══════ FORMULÁRIO ══════ -->
        <Border Grid.Column="1" Background="{StaticResource BgCard}">
            <StackPanel Width="320" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Bem-vindo de volta" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextStrong}" />
                <TextBlock Text="Entre com suas credenciais para acessar o sistema."
                           FontSize="13" Foreground="{StaticResource TextSoft}" Margin="0,6,0,0" TextWrapping="Wrap" />

                <!-- Usuário -->
                <TextBlock Text="USUÁRIO" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSoft}" Margin="0,28,0,6" />
                <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgInput}" Height="46">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource Primary}" />
                        <TextBox Grid.Column="1" x:Name="TxtLogin" BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center" FontSize="14" Text="admin" />
                    </Grid>
                </Border>

                <!-- Senha -->
                <TextBlock Text="SENHA" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSoft}" Margin="0,16,0,6" />
                <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgInput}" Height="46">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" Foreground="{StaticResource Primary}" />
                        <PasswordBox Grid.Column="1" x:Name="TxtSenha" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="14" Password="admin" />
                    </Grid>
                </Border>

                <Button Content="Esqueceu sua senha?" HorizontalAlignment="Right" Margin="0,10,0,0"
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource Primary}"
                        FontSize="12" Cursor="Hand" Padding="2" />

                <Button x:Name="BtnEntrar" Margin="0,18,0,0" Height="48" Content="Entrar"
                        FontSize="15" FontWeight="SemiBold"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Entrar_Click" />

                <Border x:Name="ErroBox" Margin="0,16,0,0" Background="#FEF2F2" BorderBrush="#FCA5A5"
                        BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Foreground="#B42318" FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0" />
                        <TextBlock x:Name="LblErro" Foreground="#B42318" FontSize="12" TextWrapping="Wrap" MaxWidth="260" />
                    </StackPanel>
                </Border>

                <Button Content="Sair do sistema" Margin="0,20,0,0" HorizontalAlignment="Center"
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSoft}"
                        FontSize="12" Cursor="Hand" Click="Sair_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
