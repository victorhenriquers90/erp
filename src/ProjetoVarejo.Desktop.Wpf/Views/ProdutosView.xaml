<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.ProdutosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Produtos" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Buscar por codigo, barras ou descricao"
                        Height="42"
                        Margin="0,0,12,0"/>
            <Button Grid.Column="1" Command="{Binding CarregarCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="42" Padding="18,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Search24" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Buscar" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Produtos}" SelectedItem="{Binding ProdutoSelecionado}"
                      Style="{StaticResource Win11DataGridStyle}"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Codigo"    Binding="{Binding Codigo}"                      Width="110"/>
                    <DataGridTextColumn Header="Descricao" Binding="{Binding Descricao}"                   Width="*" MinWidth="240"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria.Nome}"              Width="160"/>
                    <DataGridTextColumn Header="Un"        Binding="{Binding Unidade}"                     Width="70"/>
                    <DataGridTextColumn Header="Preco"     Binding="{Binding PrecoVenda, StringFormat=C2}" Width="110"/>
                    <DataGridTextColumn Header="Estoque"   Binding="{Binding Estoque, StringFormat=N3}"    Width="110"/>
                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo}"                       Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
