<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Projeto ERP"
        Height="900"
        Width="1500"
        MinHeight="720"
        MinWidth="1220"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ========== PROFESSIONAL SIDEBAR (SAP/ORACLE STYLE) ========== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo Header -->
                <Border BorderBrush="#3A5A7F" BorderThickness="0,0,0,1" Padding="18,16,18,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="32" Height="32" Background="{StaticResource Primary}" CornerRadius="4" Opacity="0.9" />
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ProjetoVarejo" Foreground="White" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Enterprise" Foreground="#9DB5D3" FontSize="10" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Menu Sections - Sem Scrollbar Visual -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,8">
                    <StackPanel Margin="0">
                        <!-- MAIN -->
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● PRINCIPAL" />
                        <Button Content="Painel (Dashboard)" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Painel_Click" />

                        <!-- MANAGEMENT -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● CADASTROS" />
                        <Button Content="Clientes" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Clientes_Click" />
                        <Button Content="Produtos" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Produtos_Click" />
                        <Button Content="Fornecedores" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Fornecedores_Click" />
                        <Button Content="Filiais" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Indisponivel_Click" />

                        <!-- OPERATIONS -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● OPERAÇÕES" />
                        <Button Content="Pedidos" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Pedidos_Click" />
                        <Button Content="Estoque" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Estoque_Click" />
                        <Button Content="Armazém" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Armazem_Click" />
                        <Button Content="Cadeia de Suprimentos" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="CadeiaSuprimentos_Click" />

                        <!-- SALES & COMMERCE -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● VENDAS" />
                        <Button Content="PDV (Ponto de Venda)" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Indisponivel_Click" />
                        <Button Content="Caixa" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Indisponivel_Click" />
                        <Button Content="E-Commerce" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Ecommerce_Click" />
                        <Button Content="Marketing" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Marketing_Click" />

                        <!-- FINANCIAL -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● FINANCEIRO" />
                        <Button Content="Contas a Pagar" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Financeiro_Click" />
                        <Button Content="Relatórios" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Relatorios_Click" />

                        <!-- PRODUCTION -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● MANUFATURA" />
                        <Button Content="Produção" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Producao_Click" />
                        <Button Content="Projetos" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Projetos_Click" />

                        <!-- HR & PEOPLE -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● PESSOAS" />
                        <Button Content="Força de Trabalho" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="ForcaTrabalho_Click" />
                        <Button Content="Apontamento de Horas" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Horas_Click" />

                        <!-- COMPLIANCE -->
                        <Separator Style="{StaticResource MenuSeparatorStyle}" Margin="12,12,12,12" />
                        <TextBlock Style="{StaticResource MenuSectionHeaderStyle}" Text="● ADMINISTRAÇÃO" />
                        <Button Content="Fiscal / NFC-e" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Indisponivel_Click" />
                        <Button Content="Auditoria" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Auditoria_Click" />
                        <Button Content="Configurações" Height="Auto" Style="{StaticResource SidebarButtonStyle}" Click="Indisponivel_Click" />
                    </StackPanel>
                </ScrollViewer>

                <!-- User & Footer -->
                <Border Grid.Row="2" BorderBrush="#3A5A7F" BorderThickness="0,1,0,0" Padding="18,16,18,16">
                    <StackPanel>
                        <Border Background="#25466B" CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock x:Name="LblUsuario"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="LblEmpresa"
                                           Margin="0,4,0,0"
                                           Foreground="#9DB5D3"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Button Content="🚪 Logout"
                                Height="Auto"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="Sair_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════ ÁREA PRINCIPAL ══════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="#E0E5F1" BorderThickness="0,0,0,1" Height="64">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LblPagina" Text="Painel" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock x:Name="LblBreadcrumb" Text="Início · Visão geral" Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>

                    <!-- Busca global -->
                    <Border Grid.Column="1" Background="#F1F3F7" CornerRadius="18" Height="36" MaxWidth="440"
                            HorizontalAlignment="Left" Margin="32,0,0,0">
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource TextSoft}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="13" />
                        </Grid>
                    </Border>

                    <!-- Ações + usuário -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource IconButtonStyle}" Content="&#xE7E7;" ToolTip="Notificações" />
                        <Button Style="{StaticResource IconButtonStyle}" Content="&#xE713;" ToolTip="Configurações" Click="Indisponivel_Click" />
                        <Border Width="1" Height="28" Background="#E0E5F1" Margin="10,0" />
                        <Border Width="38" Height="38" CornerRadius="19" Background="{StaticResource Primary}">
                            <TextBlock x:Name="LblAvatar" Text="A" Foreground="White" FontWeight="Bold" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="LblTopUsuario" Text="Usuário" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}" />
                            <TextBlock x:Name="LblTopEmpresa" Text="Empresa" FontSize="11" Foreground="{StaticResource TextSoft}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTEÚDO -->
            <Grid Grid.Row="1">
            <ScrollViewer x:Name="DashboardRoot" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24">

                    <!-- Saudação -->
                    <StackPanel Margin="0,4,0,20">
                        <TextBlock x:Name="LblSaudacao" Text="Bem-vindo!" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextStrong}" />
                        <TextBlock x:Name="LblData" Text="" FontSize="13" Foreground="{StaticResource TextSoft}" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- KPIs -->
                    <UniformGrid Columns="4">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0" Padding="18">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#EAF1FB" HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource KpiIconStyle}" Text="&#xE716;" Foreground="{StaticResource Primary}" />
                                </Border>
                                <TextBlock Text="Clientes ativos" Style="{StaticResource KpiLabelStyle}" Margin="0,14,0,0" />
                                <TextBlock x:Name="LblKpiClientes" Text="-" Style="{StaticResource KpiValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0" Padding="18">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#E9F7EF" HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource KpiIconStyle}" Text="&#xE7B8;" Foreground="#10B981" />
                                </Border>
                                <TextBlock Text="Produtos ativos" Style="{StaticResource KpiLabelStyle}" Margin="0,14,0,0" />
                                <TextBlock x:Name="LblKpiProdutos" Text="-" Style="{StaticResource KpiValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0" Padding="18">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#FEF3E2" HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource KpiIconStyle}" Text="&#xE8D1;" Foreground="#F59E0B" />
                                </Border>
                                <TextBlock Text="Fornecedores" Style="{StaticResource KpiLabelStyle}" Margin="0,14,0,0" />
                                <TextBlock x:Name="LblKpiFornecedores" Text="-" Style="{StaticResource KpiValueStyle}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardStyle}" Padding="18">
                            <StackPanel>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#FCEBEC" HorizontalAlignment="Left">
                                    <TextBlock Style="{StaticResource KpiIconStyle}" Text="&#xEAFD;" Foreground="#EF4444" />
                                </Border>
                                <TextBlock Text="Contas em aberto" Style="{StaticResource KpiLabelStyle}" Margin="0,14,0,0" />
                                <TextBlock x:Name="LblKpiFinanceiro" Text="-" Style="{StaticResource KpiValueStyle}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Atalhos + Atividade -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <!-- Atalhos rápidos -->
                        <Border Style="{StaticResource CardStyle}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Atalhos rápidos" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextStrong}" />
                                <TextBlock Text="Acesse os módulos mais usados do dia a dia." Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,16" />
                                <UniformGrid Columns="2">
                                    <Button Margin="0,0,8,8" Height="80" Click="Clientes_Click"
                                            Background="#F8FAFC" BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource Primary}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Clientes" Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="{StaticResource TextStrong}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="8,0,0,8" Height="80" Click="Produtos_Click"
                                            Background="#F8FAFC" BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#10B981" HorizontalAlignment="Center" />
                                            <TextBlock Text="Produtos" Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="{StaticResource TextStrong}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="0,8,8,0" Height="80" Click="Estoque_Click"
                                            Background="#F8FAFC" BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#F59E0B" HorizontalAlignment="Center" />
                                            <TextBlock Text="Estoque" Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="{StaticResource TextStrong}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Margin="8,8,0,0" Height="80" Click="Relatorios_Click"
                                            Background="#F8FAFC" BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#3B82F6" HorizontalAlignment="Center" />
                                            <TextBlock Text="Relatórios" Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="{StaticResource TextStrong}" />
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Atividade / status -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Status do sistema" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextStrong}" />
                                <StackPanel Margin="0,16,0,0">
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#10B981" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Banco de dados conectado" Margin="12,0,0,0" FontSize="13" Foreground="{StaticResource TextSoft}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#F59E0B" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="NFC-e em homologação" Margin="12,0,0,0" FontSize="13" Foreground="{StaticResource TextSoft}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#10B981" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Backup ativo" Margin="12,0,0,0" FontSize="13" Foreground="{StaticResource TextSoft}" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Host dos módulos (navegação dentro da janela) -->
            <ContentControl x:Name="ContentHost" Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
</Window>
