using FluentAssertions;
using Moq;
using ProjetoVarejo.Application.Contracts.Repositories;
using ProjetoVarejo.Application.Contracts.Services;
using ProjetoVarejo.Application.Services;
using ProjetoVarejo.Domain.Entities;
using ProjetoVarejo.Tests.Mocking;
using Xunit;

namespace ProjetoVarejo.Tests;

/// <summary>
/// Unit tests for ProdutoService using Moq-based IUnitOfWork mocking.
/// Tests cover product search, creation, and filtering.
/// </summary>
public class ProdutoServiceTests
{
    private readonly Mock<IUnitOfWork> _mockUnitOfWork;
    private readonly ProdutoService _produtoService;

    public ProdutoServiceTests()
    {
        _mockUnitOfWork = MockUnitOfWorkFactory.CreateMock();
        _produtoService = new ProdutoService(_mockUnitOfWork.Object);
    }

    [Fact]
    public async Task ListarParaVendaAsync_PesquisaPorDescricao()
    {
        // Arrange
        var produtos = new List<Produto>
        {
            new() { Id = 1, Codigo = "ARZ001", Descricao = "Arroz branco 5kg", PrecoVenda = 10, Ativo = true },
            new() { Id = 2, Codigo = "FEJ001", Descricao = "Feijao carioca 1kg", PrecoVenda = 8, Ativo = true },
            new() { Id = 3, Codigo = "SAL001", Descricao = "Sal refinado 1kg", PrecoVenda = 2, Ativo = true }
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produtos).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.ListarParaVendaAsync("Arroz");

        // Assert
        resultado.Should().HaveCountGreaterThanOrEqualTo(1);
        resultado.Should().Contain(p => p.Codigo == "ARZ001");
    }

    [Fact]
    public async Task ListarParaVendaAsync_PesquisaPorCodigo()
    {
        // Arrange
        var produtos = new List<Produto>
        {
            new() { Id = 1, Codigo = "ARZ001", Descricao = "Arroz branco 5kg", PrecoVenda = 10, Ativo = true },
            new() { Id = 2, Codigo = "FEJ001", Descricao = "Feijao carioca 1kg", PrecoVenda = 8, Ativo = true }
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produtos).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.ListarParaVendaAsync("FEJ");

        // Assert
        resultado.Should().HaveCountGreaterThanOrEqualTo(1);
        resultado.Should().Contain(p => p.Codigo == "FEJ001");
    }

    [Fact]
    public async Task ListarParaVendaAsync_ApenasAtivos()
    {
        // Arrange
        var produtos = new List<Produto>
        {
            new() { Id = 1, Codigo = "P001", Descricao = "Produto 1", PrecoVenda = 10, Ativo = true },
            new() { Id = 2, Codigo = "P002", Descricao = "Produto 2", PrecoVenda = 20, Ativo = false }
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produtos).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.ListarParaVendaAsync();

        // Assert
        resultado.Should().OnlyContain(p => p.Ativo);
    }

    [Fact]
    public async Task BuscarPorCodigoAsync_EncontraPorCodigo()
    {
        // Arrange
        var produto = new Produto
        {
            Id = 1,
            Codigo = "P001",
            Descricao = "Test Product",
            PrecoVenda = 10,
            Ativo = true
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produto).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.BuscarPorCodigoAsync("P001");

        // Assert
        resultado.Should().NotBeNull();
        resultado!.Codigo.Should().Be("P001");
    }

    [Fact]
    public async Task BuscarPorCodigoAsync_EncontraPorBarcode()
    {
        // Arrange
        var produto = new Produto
        {
            Id = 1,
            Codigo = "P001",
            Descricao = "Test Product",
            CodigoBarras = "7890000000001",
            PrecoVenda = 10,
            Ativo = true
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produto).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.BuscarPorCodigoAsync("7890000000001");

        // Assert
        resultado.Should().NotBeNull();
        resultado!.CodigoBarras.Should().Be("7890000000001");
    }

    [Fact]
    public async Task BuscarPorCodigoAsync_IgnoraProdutoInativo()
    {
        // Arrange
        var produto = new Produto
        {
            Id = 1,
            Codigo = "P001",
            Descricao = "Test Product",
            CodigoBarras = "7890000000001",
            PrecoVenda = 10,
            Ativo = false
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produto).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.BuscarPorCodigoAsync("7890000000001");

        // Assert
        resultado.Should().BeNull();
    }

    [Fact]
    public async Task BuscarPorIdAsync_RetornaProdutoComCategoria()
    {
        // Arrange
        var categoria = new Categoria { Id = 1, Nome = "Alimentos" };
        var produto = new Produto
        {
            Id = 1,
            Codigo = "P001",
            Descricao = "Test Product",
            PrecoVenda = 10,
            CategoriaId = 1,
            Categoria = categoria
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produto).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.BuscarPorIdAsync(1);

        // Assert
        resultado.Should().NotBeNull();
        resultado!.Id.Should().Be(1);
        resultado.Categoria.Should().NotBeNull();
    }

    [Fact]
    public async Task SalvarAsync_CriaNovoProduto()
    {
        // Arrange
        var produto = new Produto
        {
            Id = 0,
            Codigo = "P001",
            Descricao = "New Product",
            PrecoVenda = 10
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.SalvarAsync(produto);

        // Assert
        resultado.Sucesso.Should().BeTrue();
        _mockUnitOfWork.Verify(u => u.Produtos.InsertAsync(It.IsAny<Produto>()), Times.Once);
    }

    [Fact]
    public async Task SalvarAsync_CodigoJaExiste_Falha()
    {
        // Arrange
        var produtoExistente = new Produto
        {
            Id = 1,
            Codigo = "P001",
            Descricao = "Existing Product",
            PrecoVenda = 10
        };

        var novoProduto = new Produto
        {
            Id = 0,
            Codigo = "P001",
            Descricao = "New Product",
            PrecoVenda = 10
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produtoExistente).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Act
        var resultado = await _produtoService.SalvarAsync(novoProduto);

        // Assert
        resultado.Sucesso.Should().BeFalse();
        resultado.Erro.Should().Contain("código");
    }

    [Fact]
    public async Task SalvarAsync_CodigoDuplicado_DerivouAtualizacao()
    {
        // Arrange
        var produto = new Produto
        {
            Id = 1,
            Codigo = "P001",
            Descricao = "Existing Product",
            PrecoVenda = 10
        };

        var mockProdutos = new MockRepositoryBuilder<Produto>().WithData(produto).Build();
        _mockUnitOfWork.Setup(u => u.Produtos).Returns(mockProdutos.Object);

        // Atualizar mesmo produto
        produto.Descricao = "Updated Product";

        // Act
        var resultado = await _produtoService.SalvarAsync(produto);

        // Assert
        resultado.Sucesso.Should().BeTrue();
        _mockUnitOfWork.Verify(u => u.Produtos.UpdateAsync(It.IsAny<Produto>()), Times.Once);
    }
}
