<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.PagamentoVendaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pagamento"
        Height="700"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card3DStyle}" Padding="16">
            <StackPanel>
                <TextBlock Text="TOTAL A PAGAR" FontWeight="SemiBold" Foreground="{StaticResource TextSoft}" />
                <TextBlock x:Name="LblTotal"
                           Margin="0,8,0,0"
                           FontSize="44"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Style="{StaticResource Card3DStyle}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Forma de pagamento" FontWeight="SemiBold" />
                    <ComboBox x:Name="CmbForma" Height="38" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Valor" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtValor" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                </StackPanel>
                <Button Grid.Column="2"
                        Margin="10,20,0,0"
                        Width="130"
                        Height="38"
                        Content="Adicionar"
                        Background="{StaticResource Primary}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Adicionar_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card3DStyle}" Padding="8">
            <DataGrid x:Name="DgPagamentos"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      KeyDown="DgPagamentos_KeyDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Forma" Binding="{Binding Forma}" Width="2*" />
                    <DataGridTextColumn Header="Valor" Binding="{Binding Valor}" Width="1.4*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card3DStyle}" Padding="12">
                <StackPanel>
                    <TextBlock Text="FALTA" FontWeight="SemiBold" Foreground="#B42318" />
                    <TextBlock x:Name="LblFalta" Margin="0,6,0,0" FontSize="28" FontWeight="Bold" Foreground="#B42318" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource Card3DStyle}" Padding="12">
                <StackPanel>
                    <TextBlock Text="TROCO" FontWeight="SemiBold" Foreground="#0F766E" />
                    <TextBlock x:Name="LblTroco" Margin="0,6,0,0" FontSize="28" FontWeight="Bold" Foreground="#0F766E" />
                </StackPanel>
            </Border>

            <Button Grid.Column="3"
                    Margin="14,0,10,0"
                    Width="120"
                    Height="44"
                    Content="Cancelar"
                    Click="Cancelar_Click" />
            <Button Grid.Column="4"
                    x:Name="BtnConfirmar"
                    Width="190"
                    Height="44"
                    Content="Confirmar (F10)"
                    Background="#1F9D55"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Confirmar_Click" />
        </Grid>
    </Grid>
</Window>
