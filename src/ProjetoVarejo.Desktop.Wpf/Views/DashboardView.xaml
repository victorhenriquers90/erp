<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Cabeçalho -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Painel operacional"
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextDarkBrush}"/>
                <TextBlock Text="Indicadores e processos principais"
                           FontSize="13"
                           Foreground="{StaticResource AppTextMediumBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- KPI Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">

                <!-- Vendas Hoje -->
                <Border Margin="0,0,12,0" Padding="20" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Background="#FFF3E0" CornerRadius="8" Padding="8"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Money24" FontSize="22"
                                           Foreground="{StaticResource AppPrimaryBrush}"/>
                        </Border>
                        <TextBlock Text="VENDAS HOJE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="R$ 0,00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Nenhuma venda hoje"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Transações -->
                <Border Margin="0,0,12,0" Padding="20" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="8"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Cart24" FontSize="22" Foreground="#258C58"/>
                        </Border>
                        <TextBlock Text="TRANSACOES"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="0"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="vendas realizadas"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Alertas Estoque -->
                <Border Margin="0,0,12,0" Padding="20" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Background="#FFF8E1" CornerRadius="8" Padding="8"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Warning24" FontSize="22" Foreground="#F9A825"/>
                        </Border>
                        <TextBlock Text="ALERTAS ESTOQUE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="0"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="produtos abaixo do minimo"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- A Pagar -->
                <Border Padding="20" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Background="#FCE4EC" CornerRadius="8" Padding="8"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="BuildingBank24" FontSize="22" Foreground="#BB2B2B"/>
                        </Border>
                        <TextBlock Text="A PAGAR (7 DIAS)"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="R$ 0,00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="contas no prazo"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Acesso rápido -->
            <Border Padding="24" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Acesso rapido"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextDarkBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Acoes frequentes do dia a dia"
                               FontSize="12"
                               Foreground="{StaticResource AppTextMediumBrush}"
                               Margin="0,0,0,20"/>
                    <WrapPanel>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,12" Height="42" Width="172">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Cart24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Nova venda" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,12" Height="42" Width="172">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Money24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Abrir caixa" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,12" Height="42" Width="172">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Cube24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Movimentar estoque" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
