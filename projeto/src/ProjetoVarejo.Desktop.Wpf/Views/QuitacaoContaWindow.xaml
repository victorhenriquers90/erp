<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.QuitacaoContaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quitar conta"
        Height="470"
        Width="660"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2"
                           Text="Quitação de conta"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextStrong}" />

                <StackPanel Grid.Row="1" Margin="0,14,8,0">
                    <TextBlock Text="Data pagamento" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtPagamento" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,14,0,0">
                    <TextBlock Text="Forma de pagamento" FontWeight="SemiBold" />
                    <ComboBox x:Name="CmbForma" Height="38" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,10,8,0">
                    <TextBlock Text="Valor pago" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtValor" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Juros" FontWeight="SemiBold" />
                            <TextBox x:Name="TxtJuros" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Multa" FontWeight="SemiBold" />
                            <TextBox x:Name="TxtMulta" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="Desconto" FontWeight="SemiBold" />
                            <TextBox x:Name="TxtDesconto" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,14,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="112"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click" />
            <Button x:Name="BtnConfirmar"
                    Content="Confirmar quitação"
                    Width="170"
                    Height="40"
                    Background="#1F9D55"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Confirmar_Click" />
        </StackPanel>
    </Grid>
</Window>
