<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.ProdutosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Produtos" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                     md:HintAssist.Hint="Buscar por codigo, barras ou descricao"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Height="44"
                     Margin="0,0,12,0"/>
            <Button Grid.Column="1" Command="{Binding CarregarCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource AppPrimaryBrush}"
                    Foreground="White" Height="44" Padding="18,0"
                    md:ButtonAssist.CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Magnify" Width="18" Height="18"/>
                    <TextBlock Text="Buscar" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
        </Grid>
        <md:Card Grid.Row="2" Padding="0" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp1">
            <DataGrid ItemsSource="{Binding Produtos}" SelectedItem="{Binding ProdutoSelecionado}"
                      AutoGenerateColumns="False" IsReadOnly="True" RowHeight="52"
                      CanUserAddRows="False" BorderThickness="0"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="110"/>
                    <DataGridTextColumn Header="Descricao" Binding="{Binding Descricao}" Width="*" MinWidth="240"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria.Nome}" Width="160"/>
                    <DataGridTextColumn Header="Un" Binding="{Binding Unidade}" Width="70"/>
                    <DataGridTextColumn Header="Preco" Binding="{Binding PrecoVenda, StringFormat=C2}" Width="110"/>
                    <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque, StringFormat=N3}" Width="110"/>
                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>
    </Grid>
</UserControl>
