<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.CaixaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caixa"
        Height="760"
        Width="1220"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Gestão de Caixa"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextStrong}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Abertura, suprimentos, sangrias e fechamento."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,12"
                Style="{StaticResource Card3DStyle}"
                Padding="16">
            <StackPanel>
                <TextBlock x:Name="LblStatusTitulo" FontSize="24" FontWeight="Bold" />
                <TextBlock x:Name="LblStatusDetalhe" Margin="0,8,0,0" FontSize="14" Foreground="{StaticResource TextSoft}" />
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="2" Columns="5" Margin="0,0,0,12">
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12"><StackPanel><TextBlock Text="Abertura" Foreground="{StaticResource TextSoft}"/><TextBlock x:Name="LblAbertura" Margin="0,6,0,0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12"><StackPanel><TextBlock Text="Suprimentos" Foreground="{StaticResource TextSoft}"/><TextBlock x:Name="LblSuprimentos" Margin="0,6,0,0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12"><StackPanel><TextBlock Text="Sangrias" Foreground="{StaticResource TextSoft}"/><TextBlock x:Name="LblSangrias" Margin="0,6,0,0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12"><StackPanel><TextBlock Text="Total vendas" Foreground="{StaticResource TextSoft}"/><TextBlock x:Name="LblVendas" Margin="0,6,0,0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12"><StackPanel><TextBlock Text="Esperado dinheiro" Foreground="{StaticResource TextSoft}"/><TextBlock x:Name="LblEsperado" Margin="0,6,0,0" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
        </UniformGrid>

        <Border Grid.Row="3"
                Style="{StaticResource Card3DStyle}"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Vendas por forma de pagamento"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextStrong}" />
                <DataGrid Grid.Row="1"
                          Margin="0,10,0,0"
                          x:Name="DgFormas"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Forma" Binding="{Binding Forma}" Width="2*" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.5*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,14,0,0" Orientation="Horizontal">
            <Button x:Name="BtnAbrir"
                    Width="170"
                    Height="42"
                    Background="#1F9D55"
                    Foreground="White"
                    BorderThickness="0"
                    Content="Abrir Caixa"
                    Click="Abrir_Click" />
            <Button x:Name="BtnSuprimento"
                    Margin="10,0,0,0"
                    Width="160"
                    Height="42"
                    Content="Suprimento"
                    Click="Suprimento_Click" />
            <Button x:Name="BtnSangria"
                    Margin="10,0,0,0"
                    Width="160"
                    Height="42"
                    Content="Sangria"
                    Click="Sangria_Click" />
            <Button x:Name="BtnFechar"
                    Margin="10,0,0,0"
                    Width="170"
                    Height="42"
                    Background="#D64545"
                    Foreground="White"
                    BorderThickness="0"
                    Content="Fechar Caixa"
                    Click="Fechar_Click" />
            <Button Margin="24,0,0,0"
                    Width="240"
                    Height="42"
                    Content="Abrir PDV (WPF)"
                    Click="AbrirPdv_Click" />
        </StackPanel>
    </Grid>
</Window>
