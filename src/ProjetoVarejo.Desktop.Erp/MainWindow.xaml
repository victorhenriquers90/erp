<Window x:Class="ProjetoVarejo.Desktop.Erp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PROJETO ERP"
        Width="1320"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#F2F5F9"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#131D2A">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="18,20,18,14">
                    <StackPanel>
                        <TextBlock Text="PROJETO ERP" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Empresas e industrias" Margin="0,6,0,0" Foreground="#9EB3C8"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="16,12" Background="#0D1622">
                    <TextBlock Text="Base corporativa separada do Negocios" Foreground="#8FA6BD" FontSize="12"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,8">
                        <Button x:Name="BtnCompras" Click="SelecionarModulo_Click" Tag="Compras e Suprimentos"
                                Content="Compras e Suprimentos" Height="42" Margin="0,4"
                                HorizontalContentAlignment="Left" Padding="12,0"/>
                        <Button x:Name="BtnProducao" Click="SelecionarModulo_Click" Tag="Producao e PCP"
                                Content="Producao e PCP" Height="42" Margin="0,4"
                                HorizontalContentAlignment="Left" Padding="12,0"/>
                        <Button x:Name="BtnFinanceiro" Click="SelecionarModulo_Click" Tag="Financeiro Corporativo"
                                Content="Financeiro Corporativo" Height="42" Margin="0,4"
                                HorizontalContentAlignment="Left" Padding="12,0"/>
                        <Button x:Name="BtnFiscal" Click="SelecionarModulo_Click" Tag="Fiscal e Contabil"
                                Content="Fiscal e Contabil" Height="42" Margin="0,4"
                                HorizontalContentAlignment="Left" Padding="12,0"/>
                        <Button x:Name="BtnRh" Click="SelecionarModulo_Click" Tag="RH e Folha"
                                Content="RH e Folha" Height="42" Margin="0,4"
                                HorizontalContentAlignment="Left" Padding="12,0"/>
                        <Button x:Name="BtnBi" Click="SelecionarModulo_Click" Tag="BI e Indicadores"
                                Content="BI e Indicadores" Height="42" Margin="0,4"
                                HorizontalContentAlignment="Left" Padding="12,0"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#172334" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="PAINEL ERP" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtSubtituloTopo" Text="Gestao corporativa com foco em processos internos"
                                   Foreground="#A8BCD0" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#2B3E55" CornerRadius="8" Padding="12,6" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatusTopo" Text="Modulo ativo: Compras e Suprimentos" Foreground="#E5EDF5" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="0,14,0,0" Background="#E7EEF6" BorderBrush="#D3DEE9" BorderThickness="1" CornerRadius="10" Padding="12">
                <TextBlock x:Name="TxtMensagemModulo"
                           Text="Compras e Suprimentos conectado com banco: fornecedores carregados em tempo real."
                           Foreground="#30465A"/>
            </Border>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid x:Name="PainelCompras">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#D5E0EB" BorderThickness="1" CornerRadius="12" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1.1*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Fornecedores homologados" FontSize="18" FontWeight="Bold" Foreground="#1B2B3D"/>
                                    <TextBlock Text="Base usada para pedidos de compra" Foreground="#5A6F84"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right" x:Name="BtnAtualizarFornecedores" Content="Atualizar" Width="108" Height="34" Click="BtnAtualizarFornecedores_Click"/>
                            </DockPanel>

                            <TextBox Grid.Row="1" x:Name="TxtFiltroFornecedor" Height="34" Padding="10,6"
                                     TextChanged="TxtFiltroFornecedor_TextChanged"
                                     ToolTip="Digite nome fantasia, razao social ou CNPJ"/>

                            <DataGrid Grid.Row="2" Margin="0,12,0,0" x:Name="DgFornecedores"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowHeight="34">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Razao Social" Binding="{Binding RazaoSocial}" Width="2.2*"/>
                                    <DataGridTextColumn Header="Fantasia" Binding="{Binding NomeFantasia}" Width="1.6*"/>
                                    <DataGridTextColumn Header="CNPJ" Binding="{Binding Cnpj}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Cidade/UF" Binding="{Binding CidadeUf}" Width="1*"/>
                                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="1*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Grid Grid.Row="3" Margin="0,14,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Pedidos cadastrados" FontSize="17" FontWeight="Bold" Foreground="#1B2B3D"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ComboBox x:Name="CmbFiltroStatus" Width="130" Height="30">
                                            <ComboBoxItem Content="Todos"/>
                                            <ComboBoxItem Content="Rascunho"/>
                                            <ComboBoxItem Content="Enviado"/>
                                            <ComboBoxItem Content="Aprovado"/>
                                            <ComboBoxItem Content="Parcial"/>
                                            <ComboBoxItem Content="Recebido"/>
                                            <ComboBoxItem Content="Cancelado"/>
                                        </ComboBox>
                                        <DatePicker x:Name="DpFiltroDe" Width="130" Height="30" Margin="8,0,0,0"/>
                                        <DatePicker x:Name="DpFiltroAte" Width="130" Height="30" Margin="8,0,0,0"/>
                                        <Button Width="74" Height="30" Margin="8,0,0,0" Content="Filtrar" Click="BtnFiltrarPedidos_Click"/>
                                        <Button Width="72" Height="30" Margin="8,0,0,0" Content="Limpar" Click="BtnLimparFiltroPedidos_Click"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Width="95" Height="32" Margin="0,0,8,0" Content="Atualizar" Click="BtnAtualizarPedidos_Click"/>
                                    <Button Width="86" Height="32" Margin="0,0,8,0" Content="Editar" Click="BtnEditarPedido_Click"/>
                                    <Button Width="78" Height="32" Content="Novo" Click="BtnNovoPedido_Click"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="4" x:Name="DgPedidos"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowHeight="32">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Numero" Binding="{Binding Numero}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Fornecedor" Binding="{Binding Fornecedor}" Width="2*"/>
                                    <DataGridTextColumn Header="Data" Binding="{Binding DataEmissao}" Width="1*"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="0.9*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#D5E0EB" BorderThickness="1" CornerRadius="12" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Pedido de compra" FontSize="18" FontWeight="Bold" Foreground="#1B2B3D"/>
                            <TextBlock x:Name="TxtModoPedido" Grid.Row="1" Margin="0,6,0,10" Text="Modo: novo pedido"
                                       Foreground="#5A6F84"/>

                            <TextBlock Grid.Row="2" Text="Observacao do pedido" Foreground="#5A6F84"/>
                            <TextBox Grid.Row="3" x:Name="TxtObservacaoPedido" Height="56" Padding="10,8"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalContentAlignment="Top" ToolTip="Observacao geral da compra"/>

                            <DockPanel Grid.Row="4" LastChildFill="True">
                                <ComboBox DockPanel.Dock="Left" x:Name="CmbProdutoItem" Width="260" Height="34"
                                          Margin="0,0,8,0"
                                          DisplayMemberPath="Exibicao"
                                          SelectionChanged="CmbProdutoItem_SelectionChanged"
                                          ToolTip="Selecione o produto do item"/>
                                <TextBox x:Name="TxtItemDescricao" Height="34" Padding="10,6" ToolTip="Descricao do item"/>
                            </DockPanel>

                            <Grid Grid.Row="5" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtQtd" Grid.Column="0" Height="34" Padding="10,6" ToolTip="Quantidade"/>
                                <TextBox x:Name="TxtValorUnitario" Grid.Column="2" Height="34" Padding="10,6" ToolTip="Valor unitario"/>
                            </Grid>

                            <StackPanel Grid.Row="6" Margin="0,10,0,0" Orientation="Horizontal">
                                <Button Width="120" Height="34" Content="Adicionar item" Click="BtnAdicionarItem_Click"/>
                                <Button Margin="8,0,0,0" Width="108" Height="34" Content="Remover item" Click="BtnRemoverItem_Click"/>
                                <Button Margin="8,0,0,0" Width="96" Height="34" Content="Limpar itens" Click="BtnLimparItens_Click"/>
                            </StackPanel>

                            <ListView Grid.Row="7" Margin="0,12,0,12" x:Name="LvItensPedido">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Produto" Width="100" DisplayMemberBinding="{Binding ProdutoRef}"/>
                                        <GridViewColumn Header="Item" Width="190" DisplayMemberBinding="{Binding Descricao}"/>
                                        <GridViewColumn Header="Qtd" Width="55" DisplayMemberBinding="{Binding Quantidade}"/>
                                        <GridViewColumn Header="Recebida" Width="70" DisplayMemberBinding="{Binding QuantidadeRecebidaFormatada}"/>
                                        <GridViewColumn Header="Pendente" Width="70" DisplayMemberBinding="{Binding QuantidadePendenteFormatada}"/>
                                        <GridViewColumn Header="Vlr Unit" Width="80" DisplayMemberBinding="{Binding ValorUnitarioFormatado}"/>
                                        <GridViewColumn Header="Subtotal" Width="90" DisplayMemberBinding="{Binding SubtotalFormatado}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Grid Grid.Row="8" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtQtdReceber" Grid.Column="0" Height="34" Padding="10,6" ToolTip="Quantidade recebida agora"/>
                                <TextBox x:Name="TxtVlrUnitRecebido" Grid.Column="2" Height="34" Padding="10,6" ToolTip="Valor unitario recebido (opcional)"/>
                                <Button Grid.Column="4" Width="140" Height="34" Content="Receber item" Click="BtnReceberItem_Click"/>
                                <Button Grid.Column="6" Width="120" Height="34" Content="Historico" Click="BtnHistoricoRecebimento_Click"/>
                            </Grid>

                            <DockPanel Grid.Row="9">
                                <TextBlock Text="Total do pedido:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2C4358"/>
                                <TextBlock x:Name="TxtTotalPedido" Text="R$ 0,00" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#1F7A3D"/>
                                <Button x:Name="BtnSalvarPedido" DockPanel.Dock="Right" Width="140" Height="34" Content="Salvar pedido" Click="BtnSalvarPedido_Click"/>
                            </DockPanel>

                            <DockPanel Grid.Row="10" Margin="0,10,0,0">
                                <ComboBox x:Name="CmbStatusPedido" Width="160" Height="32">
                                    <ComboBoxItem Content="Rascunho"/>
                                    <ComboBoxItem Content="Enviado"/>
                                    <ComboBoxItem Content="Aprovado"/>
                                    <ComboBoxItem Content="Parcial"/>
                                    <ComboBoxItem Content="Recebido"/>
                                    <ComboBoxItem Content="Cancelado"/>
                                </ComboBox>
                                <Button Margin="8,0,0,0" Width="130" Height="32" Content="Atualizar status" Click="BtnAtualizarStatus_Click"/>
                                <Button Margin="8,0,0,0" Width="140" Height="32" Content="Receber + estoque" Click="BtnReceberPedido_Click"/>
                                <Button Margin="8,0,0,0" Width="120" Height="32" Content="Excluir pedido" Click="BtnExcluirPedido_Click"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="PainelPlaceholder" Visibility="Collapsed"
                        Background="White" BorderBrush="#D5E0EB" BorderThickness="1" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock x:Name="TxtTituloPlaceholder" Text="Modulo em implantacao" FontSize="24" FontWeight="Bold" Foreground="#1F2F42"/>
                        <TextBlock x:Name="TxtDescricaoPlaceholder" Margin="0,10,0,0" TextWrapping="Wrap"
                                   Text="Este modulo sera ativado nas proximas fases da migracao ERP."
                                   Foreground="#4F6479" FontSize="14"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
