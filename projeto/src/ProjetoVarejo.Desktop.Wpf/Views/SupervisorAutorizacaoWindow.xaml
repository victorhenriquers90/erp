<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.SupervisorAutorizacaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autorização de Supervisor"
        Height="340"
        Width="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card3DStyle}" Padding="16">
            <StackPanel>
                <TextBlock x:Name="LblTitulo"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />
                <TextBlock x:Name="LblMensagem"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextSoft}" />

                <TextBlock Margin="0,12,0,4" Text="Login do supervisor" FontWeight="SemiBold" />
                <TextBox x:Name="TxtLogin" Height="40" VerticalContentAlignment="Center" Padding="10,0" />

                <TextBlock Margin="0,12,0,4" Text="Senha do supervisor" FontWeight="SemiBold" />
                <PasswordBox x:Name="TxtSenha" Height="40" Padding="10,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="110" Height="38" Margin="0,0,10,0" Click="Cancelar_Click" />
            <Button Content="Autorizar" Width="130" Height="38" Background="{StaticResource Primary}" Foreground="White" BorderThickness="0" Click="Autorizar_Click" />
        </StackPanel>
    </Grid>
</Window>
