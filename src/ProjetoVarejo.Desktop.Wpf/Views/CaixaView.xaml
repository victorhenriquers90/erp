<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.CaixaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Caixa" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="{Binding Status}" Style="{StaticResource SectionSubtitleStyle}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Command="{Binding CarregarCommand}" Height="40"
                    Style="{StaticResource SecondaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Atualizar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Abertura e movimentos -->
            <Border Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Abertura e movimentos"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <!-- Abrir caixa -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Text="{Binding ValorAbertura, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Valor de abertura" Height="40"/>
                        <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding AbrirCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Money24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Abrir caixa" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Sangria / Suprimento -->
                    <Grid Grid.Row="2" Margin="0,0,0,12" IsEnabled="{Binding TemCaixaAberto}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.6*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Text="{Binding ValorMovimento, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Valor" Height="40"/>
                        <ui:TextBox Grid.Column="1" Margin="8,0,0,0" Height="40"
                                    Text="{Binding MotivoMovimento, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Motivo"/>
                        <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding SangriaCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowDown24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Sangria" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Margin="8,0,0,0" Command="{Binding SuprimentoCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowUp24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Suprimento" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Fechar caixa -->
                    <Grid Grid.Row="3" IsEnabled="{Binding TemCaixaAberto}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Text="{Binding ValorFechamentoInformado, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Valor contado no fechamento" Height="40"/>
                        <ui:TextBox Grid.Column="1" Margin="8,0,0,0" Height="40"
                                    Text="{Binding ObservacaoFechamento, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Observacao"/>
                        <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding FecharCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Fechar caixa" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Resumo -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Resumo do caixa"
                               FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,12">
                        <TextBlock Text="Dinheiro"  Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="{Binding TotalDinheiro, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        <TextBlock Text="Debito"    Foreground="{StaticResource AppTextMediumBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding TotalDebito, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        <TextBlock Text="Credito"   Foreground="{StaticResource AppTextMediumBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding TotalCredito, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        <TextBlock Text="Pix"       Foreground="{StaticResource AppTextMediumBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding TotalPix, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,6,0,0"/>
                        <TextBlock Text="Outros"    Foreground="{StaticResource AppTextMediumBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding TotalOutros, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </UniformGrid>

                    <Rectangle Grid.Row="2" Height="1" Fill="#EBEBEB" Margin="0,0,0,12"/>

                    <UniformGrid Grid.Row="3" Columns="2" Margin="0,0,0,12">
                        <TextBlock Text="Suprimentos" Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="{Binding TotalSuprimentos, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        <TextBlock Text="Sangrias"   Foreground="{StaticResource AppTextMediumBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding TotalSangrias, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold" Margin="0,6,0,0"/>
                    </UniformGrid>

                    <Rectangle Grid.Row="4" Height="1" Fill="#EBEBEB" Margin="0,0,0,12"/>

                    <UniformGrid Grid.Row="5" Columns="2">
                        <TextBlock Text="Saldo esperado (dinheiro)" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SaldoEsperado, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{StaticResource AppPrimaryBrush}"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding Mensagem}" Foreground="#18794E" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Erro}" Foreground="{StaticResource AppErrorBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Diferenca, StringFormat=Diferenca do ultimo fechamento: {0:C2}}" Margin="0,4,0,0" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
