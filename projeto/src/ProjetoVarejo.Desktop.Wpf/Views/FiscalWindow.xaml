<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.FiscalWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Fiscal e obrigacoes"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextStrong}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Acompanhamento de NFC-e, contingência e conformidade cadastral."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card3DStyle}" Padding="12" Margin="0,16,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="De" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtDe" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Até" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtAte" Width="140" />
                </StackPanel>
                <UniformGrid Grid.Column="2" Columns="5" Margin="20,0,0,0">
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Autorizadas" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblAutorizadas" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Rejeitadas" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblRejeitadas" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Canceladas" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblCanceladas" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Contingência" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblContingencia" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Ambiente" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblAmbiente" Margin="0,6,0,0" FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
                <Button Grid.Column="3"
                        Width="120"
                        Height="36"
                        Margin="12,20,0,0"
                        Content="Atualizar"
                        Click="Atualizar_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card3DStyle}" Padding="8">
            <TabControl>
                <TabItem Header="Notas fiscais">
                    <DataGrid x:Name="DgNotas" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="1*" />
                            <DataGridTextColumn Header="Série" Binding="{Binding Serie}" Width="0.8*" />
                            <DataGridTextColumn Header="Venda" Binding="{Binding Venda}" Width="1.2*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.3*" />
                            <DataGridTextColumn Header="Autorizada em" Binding="{Binding AutorizadaEm}" Width="1.6*" />
                            <DataGridTextColumn Header="Chave de acesso" Binding="{Binding Chave}" Width="2.8*" />
                            <DataGridTextColumn Header="Mensagem Sefaz" Binding="{Binding Mensagem}" Width="2.8*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Conformidade">
                    <DataGrid x:Name="DgConformidade" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="2.2*" />
                            <DataGridTextColumn Header="Situação" Binding="{Binding Situacao}" Width="1.2*" />
                            <DataGridTextColumn Header="Detalhe" Binding="{Binding Detalhe}" Width="3.8*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
