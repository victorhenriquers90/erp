<Window x:Class="ProjetoVarejo.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ProjetoVarejo.Desktop.Wpf.ViewModels"
        xmlns:views="clr-namespace:ProjetoVarejo.Desktop.Wpf.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PROJETO NEGOCIOS"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI">

    <!-- DataTemplate routing: ViewModel → View -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
            <views:ClientesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProdutosViewModel}">
            <views:ProdutosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FornecedoresViewModel}">
            <views:FornecedoresView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EstoqueViewModel}">
            <views:EstoqueView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinanceiroViewModel}">
            <views:FinanceiroView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VendasViewModel}">
            <views:VendasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CaixaViewModel}">
            <views:CaixaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsuariosViewModel}">
            <views:UsuariosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FiliaisViewModel}">
            <views:FiliaisView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
            <views:RelatoriosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditoriaViewModel}">
            <views:AuditoriaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FiscalViewModel}">
            <views:FiscalView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OperacoesViewModel}">
            <views:OperacoesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdministracaoSistemaViewModel}">
            <views:AdministracaoSistemaView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource AppSidebarBrush}">
            <DockPanel>

                <!-- Logo / Cabeçalho -->
                <Border DockPanel.Dock="Top" Padding="20,22,20,14">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="36" Height="36" CornerRadius="10"
                                Background="#C47412" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Store24" FontSize="18" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="PROJETO NEGOCIOS"
                                       Foreground="White"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Sistema PDV"
                                       Foreground="#5A7A90"
                                       FontSize="11" Margin="0,1,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Rectangle DockPanel.Dock="Top" Height="1" Fill="#1E2E40" Margin="16,0"/>

                <!-- Rodapé usuário -->
                <Border DockPanel.Dock="Bottom" Padding="16,12" Background="#0D1824">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="17"
                                Background="#1E3048" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Person24" FontSize="18" Foreground="#C47412"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NomeUsuario}"
                                       Foreground="White"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Empresa}"
                                       Foreground="#5A7A90"
                                       FontSize="11" Margin="0,1,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Menu de navegação -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel Margin="8,0">

                        <!-- PRINCIPAL -->
                        <TextBlock Text="PRINCIPAL" Foreground="#3A5468"
                                   FontSize="10" FontWeight="Bold" Margin="12,8,0,6"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirDashboardCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Home24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Painel" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- CADASTROS -->
                        <TextBlock Text="CADASTROS" Foreground="#3A5468"
                                   FontSize="10" FontWeight="Bold" Margin="12,16,0,6"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirClientesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="People24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Clientes" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirProdutosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Box24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Produtos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFornecedoresCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="VehicleTruck24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Fornecedores" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFiliaisCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="BuildingShop24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Filiais" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- VENDAS -->
                        <TextBlock Text="VENDAS" Foreground="#3A5468"
                                   FontSize="10" FontWeight="Bold" Margin="12,16,0,6"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirVendasCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Cart24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="PDV" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirCaixaCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Money24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Caixa" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFiscalCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Receipt24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Fiscal e pagamentos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- OPERACAO -->
                        <TextBlock Text="OPERACAO" Foreground="#3A5468"
                                   FontSize="10" FontWeight="Bold" Margin="12,16,0,6"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirEstoqueCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Cube24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Estoque" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFinanceiroCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Financeiro" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirRelatoriosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Relatorios" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirOperacoesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CalendarClock24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Rotinas da loja" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- GESTAO -->
                        <TextBlock Text="GESTAO" Foreground="#3A5468"
                                   FontSize="10" FontWeight="Bold" Margin="12,16,0,6"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirUsuariosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="PersonSettings24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Usuarios" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirAdministracaoSistemaCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Settings24" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Administracao" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Rectangle Height="12"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══ CONTEÚDO PRINCIPAL ════════════════════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- Topbar Win11 -->
            <Border DockPanel.Dock="Top" Height="52"
                    Background="White"
                    BorderBrush="#EBEBEB" BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid>
                    <TextBlock Text="{Binding PaginaTitulo}"
                               Foreground="{StaticResource AppTextDarkBrush}"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border CornerRadius="20" Background="#F3F3F3" Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Person24" FontSize="16"
                                               Foreground="{StaticResource AppPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding NomeUsuario}"
                                           Foreground="{StaticResource AppTextDarkBrush}"
                                           FontSize="13" FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Margin="7,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Mensagem de erro global -->
            <Border DockPanel.Dock="Top"
                    Margin="24,12,24,0"
                    Padding="12,10"
                    Background="#FDECEC"
                    BorderBrush="#F3B7B7"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding Erro, Converter={StaticResource StringToVisibilityConverter}}">
                <DockPanel>
                    <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="16"
                                   Foreground="#BB2B2B" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Erro}" Foreground="#8E1E1E"
                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Área de conteúdo via DataTemplate routing -->
            <ContentControl Content="{Binding PaginaAtual}" Margin="24"/>
        </DockPanel>
    </Grid>
</Window>
