<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projeto ERP - Acesso"
        Height="680"
        Width="1120"
        MinHeight="620"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BgApp}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BrandGradient}">
            <Grid Margin="58,52">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource Primary}">
                        <TextBlock Text="&#xE719;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="26"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Projeto ERP"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="ENTERPRISE"
                                   Foreground="#9DBDE0"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <Grid SnapsToDevicePixels="True">
                        <TextBlock Text="GEST&#xC3;O ESTRAT&#xC9;GICA"
                                   Margin="2,2,0,0"
                                   Foreground="#2D6B8BB0"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType" />
                        <TextBlock Text="GEST&#xC3;O ESTRAT&#xC9;GICA"
                                   Foreground="White"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType" />
                    </Grid>
                    <Grid Margin="0,4,0,0" SnapsToDevicePixels="True">
                        <TextBlock Text="PARA O SEU NEG&#xD3;CIO"
                                   Margin="2,2,0,0"
                                   Foreground="#2D6B8BB0"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType" />
                        <TextBlock Text="PARA O SEU NEG&#xD3;CIO"
                                   Foreground="White"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   TextOptions.TextFormattingMode="Display"
                                   TextOptions.TextRenderingMode="ClearType" />
                    </Grid>

                    <TextBlock Text="Planejamento, estoque, financeiro e fiscal (NFC-e) em um so lugar."
                               Foreground="#B8CDE3"
                               FontSize="15"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"
                               LineHeight="23" />

                    <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                        <Border Background="#22FFFFFF" CornerRadius="18" Padding="13,7" Margin="0,0,10,0">
                            <TextBlock Text="NFC-e" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="18" Padding="13,7" Margin="0,0,10,0">
                            <TextBlock Text="Estoque" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#22FFFFFF" CornerRadius="18" Padding="13,7">
                            <TextBlock Text="Financeiro" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="&#xA9; 2026 Projeto ERP &#xB7; v1.0.0"
                           Foreground="#7EA0C4"
                           FontSize="11" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F7F9FC">
            <Border MaxWidth="520"
                    MinWidth="340"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    BorderBrush="#E2E6EE"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="34"
                    Effect="{StaticResource CardShadowSoft}">
                <StackPanel>
                    <TextBlock Text="Bem-vindo de volta"
                               FontSize="27"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextStrong}" />
                    <TextBlock Text="Entre com suas credenciais para continuar."
                               FontSize="13"
                               Foreground="{DynamicResource TextSoft}"
                               Margin="0,7,0,0"
                               TextWrapping="Wrap" />

                    <TextBlock Text="USUARIO"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextSoft}"
                               Margin="0,30,0,7" />
                    <Border x:Name="LoginField"
                            BorderBrush="#DDE3EC"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="White"
                            Height="50"
                            PreviewMouseLeftButtonDown="LoginField_PreviewMouseLeftButtonDown">
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Primary}"
                                       IsHitTestVisible="False" />
                            <TextBox Grid.Column="1"
                                     x:Name="TxtLogin"
                                     Style="{x:Null}"
                                     BorderThickness="0"
                                     Background="White"
                                     Foreground="#0C1428"
                                     CaretBrush="#0067C0"
                                     VerticalContentAlignment="Center"
                                     FontSize="15"
                                     Padding="6,0"
                                     Text=""
                                     IsReadOnly="False"
                                     IsTabStop="True"
                                     Focusable="True"
                                     TabIndex="0"
                                     ToolTip="Informe seu usuário"
                                     AutomationProperties.Name="Usuário" />
                        </Grid>
                    </Border>

                    <TextBlock Text="SENHA"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextSoft}"
                               Margin="0,18,0,7" />
                    <Border x:Name="SenhaField"
                            BorderBrush="#DDE3EC"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="White"
                            Height="50"
                            PreviewMouseLeftButtonDown="SenhaField_PreviewMouseLeftButtonDown">
                        <Grid Margin="14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="36" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE72E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Primary}"
                                       IsHitTestVisible="False" />
                            <PasswordBox Grid.Column="1"
                                         x:Name="TxtSenha"
                                         Style="{x:Null}"
                                         BorderThickness="0"
                                         Background="White"
                                         Foreground="#0C1428"
                                         CaretBrush="#0067C0"
                                         VerticalContentAlignment="Center"
                                         FontSize="15"
                                         Padding="6,0"
                                         Password=""
                                         IsTabStop="True"
                                         Focusable="True"
                                         TabIndex="1"
                                         AutomationProperties.Name="Senha" />
                            <TextBox Grid.Column="1"
                                     x:Name="TxtSenhaPlain"
                                     Visibility="Collapsed"
                                     Style="{x:Null}"
                                     BorderThickness="0"
                                     Background="White"
                                     Foreground="#0C1428"
                                     CaretBrush="#0067C0"
                                     VerticalContentAlignment="Center"
                                     FontSize="15"
                                     Padding="6,0"
                                     IsTabStop="True"
                                     Focusable="True"
                                     TabIndex="1"
                                     AutomationProperties.Name="Senha (texto)" />
                            <ToggleButton Grid.Column="2"
                                          x:Name="BtnToggleSenha"
                                          Width="28"
                                          Height="28"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Mostrar senha"
                                          Click="BtnToggleSenha_Click">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ToggleButton>
                        </Grid>
                    </Border>

                    <Button x:Name="BtnEntrar"
                            Margin="0,24,0,0"
                            Height="50"
                            Content="Entrar"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Entrar_Click"
                            ToolTip="Entrar no sistema"
                            AutomationProperties.Name="Entrar" />

                    <Border x:Name="ErroBox"
                            Margin="0,14,0,0"
                            Background="#FEF2F2"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Visibility="Collapsed"
                            AutomationProperties.Name="Mensagem de erro"
                            AutomationProperties.LiveSetting="Polite">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE783;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#B91C1C"
                                       FontSize="15"
                                       VerticalAlignment="Top"
                                       Margin="0,1,10,0" />
                            <TextBlock x:Name="LblErro"
                                       Foreground="#B91C1C"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       MaxWidth="260" />
                        </StackPanel>
                    </Border>

                    <Button Content="Sair do sistema"
                            Margin="0,22,0,0"
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource TextSoft}"
                            FontSize="12"
                            Cursor="Hand"
                            Click="Sair_Click" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
