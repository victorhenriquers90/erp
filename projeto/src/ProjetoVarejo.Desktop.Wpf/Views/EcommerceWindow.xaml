<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.EcommerceWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Desempenho digital com base nas vendas consolidadas do ERP."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card3DStyle}" Padding="12" Margin="0,16,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="De" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtDe" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Até" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtAte" Width="140" />
                </StackPanel>
                <UniformGrid Grid.Column="2" Columns="4" Margin="20,0,0,0">
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Pedidos" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblPedidos" Margin="0,6,0,0" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Faturamento" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblFaturamento" Margin="0,6,0,0" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Ticket medio" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblTicket" Margin="0,6,0,0" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card3DStyle}" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Clientes compradores" Foreground="{StaticResource TextSoft}" />
                            <TextBlock x:Name="LblClientes" Margin="0,6,0,0" FontSize="22" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
                <Button Grid.Column="3"
                        Width="120"
                        Height="36"
                        Margin="12,20,0,0"
                        Content="Atualizar"
                        Click="Atualizar_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card3DStyle}" Padding="8">
            <TabControl>
                <TabItem Header="Top produtos">
                    <DataGrid x:Name="DgTopProdutos" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produto" Binding="{Binding Produto}" Width="3*" />
                            <DataGridTextColumn Header="Qtd vendida" Binding="{Binding Quantidade}" Width="1.2*" />
                            <DataGridTextColumn Header="Faturamento" Binding="{Binding Faturamento}" Width="1.6*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Clientes recorrentes">
                    <DataGrid x:Name="DgClientes" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" Width="2.8*" />
                            <DataGridTextColumn Header="Pedidos" Binding="{Binding Pedidos}" Width="1*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.4*" />
                            <DataGridTextColumn Header="Ultima compra" Binding="{Binding UltimaCompra}" Width="1.5*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
