<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.FiscalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Fiscal e pagamentos" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="NFC-e, notas fiscais, TEF e PIX" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Modulos}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="300" Height="158" Margin="0,0,16,16" Padding="18"
                            Style="{StaticResource CardStyle}" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="40" Height="40" CornerRadius="10" Background="#FFF4E5">
                                    <ui:SymbolIcon Symbol="{Binding Icone}" FontSize="20"
                                                   Foreground="#D38316"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Nome}" FontSize="15" FontWeight="SemiBold"
                                           Margin="12,8,0,0" Foreground="{StaticResource AppTextDarkBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <TextBlock Grid.Row="1" Text="{Binding Descricao}" TextWrapping="Wrap"
                                       Margin="0,12,0,0" Foreground="{StaticResource AppTextMediumBrush}"
                                       FontSize="12"/>
                            <Border Grid.Row="2" HorizontalAlignment="Left" CornerRadius="8"
                                    Background="#E8F5EC" Padding="10,5">
                                <TextBlock Text="{Binding Status}" Foreground="#14823B"
                                           FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
