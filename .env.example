# PHASE 12: Environment Configuration Template
# Copy this file to .env and customize for your environment

# Database
MSSQL_SA_PASSWORD=AdminPassword123!

# JWT
JWT_SECRET_KEY=sua-chave-secreta-256-bits-minimo-32-caracteres-nao-esqueca

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Redis (for caching)
REDIS_CONNECTION=redis:6379
REDIS_ENABLED=true

# API Configuration
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000

# Database Configuration (for tests)
DATABASE_TIMEOUT_SECONDS=10

# Logging
LOG_LEVEL=Information
SERILOG_MIN_LEVEL=Information

# Cors
CORS_ALLOWED_ORIGINS=https://localhost:3000,https://localhost:5173

# Health Checks
HEALTH_CHECK_INTERVAL=30
