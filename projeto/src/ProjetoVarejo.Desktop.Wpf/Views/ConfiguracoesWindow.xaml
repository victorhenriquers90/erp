<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.ConfiguracoesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource BgApp}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24" MaxWidth="900" HorizontalAlignment="Left">

            <TextBlock Text="Parâmetros e manutenção do sistema." Style="{StaticResource PageSubtitleStyle}" Margin="0,8,0,0" />

            <!-- APARÊNCIA -->
            <Border Style="{StaticResource Card3DStyle}" Padding="20" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Aparência" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                    <TextBlock Text="Escolha o tema visual do sistema." Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,14" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnTemaClaro" Width="160" Height="42" Margin="0,0,12,0" Click="TemaClaro_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Tema claro" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnTemaEscuro" Width="160" Height="42" Click="TemaEscuro_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Tema escuro" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- INFORMAÇÕES DO SISTEMA -->
            <Border Style="{StaticResource Card3DStyle}" Padding="20" Margin="0,16,0,16">
                <StackPanel>
                    <TextBlock Text="Informações do sistema" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="PRODUTO" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock Text="Projeto ERP — Enterprise" FontSize="14" Foreground="{DynamicResource TextStrong}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                            <TextBlock Text="VERSÃO" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock Text="1.0.0" FontSize="14" Foreground="{DynamicResource TextStrong}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="EMPRESA ATIVA" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="LblEmpresa" Text="-" FontSize="14" Foreground="{DynamicResource TextStrong}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="USUÁRIO LOGADO" Style="{StaticResource KpiLabelStyle}" />
                            <TextBlock x:Name="LblUsuario" Text="-" FontSize="14" Foreground="{DynamicResource TextStrong}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BACKUP -->
            <Border Style="{StaticResource Card3DStyle}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Backup do banco de dados" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                    <TextBlock Text="Gere uma cópia de segurança do banco de dados. Recomendado fazer regularmente."
                               Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,16" />

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnBackup" Content="Fazer backup agora" Width="190" Height="42"
                                Style="{StaticResource PrimaryButtonStyle}" Click="Backup_Click" />
                    </StackPanel>

                    <Border x:Name="ResultadoBox" Margin="0,16,0,0" Background="#ECFDF5" BorderBrush="#A7F3D0"
                            BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#047857" FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0" />
                            <TextBlock x:Name="LblResultado" Foreground="#065F46" FontSize="12" TextWrapping="Wrap" MaxWidth="640" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ALERTAS WHATSAPP -->
            <Border Style="{StaticResource Card3DStyle}" Padding="20" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Alertas WhatsApp" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                    <TextBlock Text="Receba notificações automáticas no WhatsApp quando uma filial ficar offline ou o caixa não for aberto no horário."
                               Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,16" />

                    <CheckBox x:Name="ChkAlertasAtivos" Content="Ativar alertas automáticos" Margin="0,0,0,14"
                              Foreground="{DynamicResource TextStrong}" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Telefone do gerente:" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Foreground="{DynamicResource TextNormal}" />
                        <TextBox x:Name="TxtTelefoneGerente" Grid.Column="1" Height="36"
                                 Text="+55 11 99999-9999" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Caixa deve abrir até:" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Foreground="{DynamicResource TextNormal}" />
                        <TextBox x:Name="TxtHoraCaixa" Grid.Column="1" Height="36"
                                 Text="9" />
                        <TextBlock Text=":00" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextNormal}" />
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Verificar a cada:" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   Foreground="{DynamicResource TextNormal}" />
                        <TextBox x:Name="TxtIntervalo" Grid.Column="1" Height="36"
                                 Text="15" />
                        <TextBlock Text="minutos" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextNormal}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnSalvarAlertas" Content="Salvar configuração de alertas"
                                Width="240" Height="42"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SalvarAlertas_Click" />
                    </StackPanel>

                    <Border x:Name="AlertasBox" Margin="0,14,0,0" Background="#ECFDF5" BorderBrush="#A7F3D0"
                            BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#047857"
                                       FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0" />
                            <TextBlock x:Name="LblAlertas" Foreground="#065F46" FontSize="12"
                                       TextWrapping="Wrap" MaxWidth="640" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DADOS DE DEMONSTRAÇÃO -->
            <Border Style="{StaticResource Card3DStyle}" Padding="20" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Dados de demonstração" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                    <TextBlock Text="Popula clientes, fornecedores e contas de exemplo (marcados como [DEMO]) para apresentações. Só adiciona se houver poucos registros."
                               Style="{StaticResource PageSubtitleStyle}" Margin="0,4,0,16" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnDemo" Content="Popular dados de demonstração" Width="270" Height="42"
                                Click="Demo_Click" />
                    </StackPanel>
                    <Border x:Name="DemoBox" Margin="0,16,0,0" Background="#EFF6FF" BorderBrush="#BFDBFE"
                            BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                        <TextBlock x:Name="LblDemo" Foreground="#1E40AF" FontSize="12" TextWrapping="Wrap" MaxWidth="640" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
