<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.ContaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conta financeira"
        Height="690"
        Width="920"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.ColumnSpan="2"
                               Text="Cadastro de conta"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextStrong}" />

                    <StackPanel Grid.Row="1" Margin="0,14,8,0">
                        <TextBlock Text="Tipo" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbTipo" Height="38" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,14,0,0">
                        <TextBlock Text="Valor (R$)" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtValor" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <TextBlock Text="Descrição" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtDescricao" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,10,8,0">
                        <TextBlock Text="Documento" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtDocumento" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Data emissão" FontWeight="SemiBold" />
                        <DatePicker x:Name="DtEmissao" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,10,8,0">
                        <TextBlock Text="Vencimento" FontWeight="SemiBold" />
                        <DatePicker x:Name="DtVencimento" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Cliente (opcional)" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbCliente" Height="38" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,10,8,0">
                        <TextBlock Text="Fornecedor (opcional)" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbFornecedor" Height="38" />
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Observação" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtObservacao"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 Padding="10,8" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,14,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="112"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click" />
            <Button x:Name="BtnSalvar"
                    Content="Salvar"
                    Width="130"
                    Height="40"
                    Background="{StaticResource Primary}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Salvar_Click" />
        </StackPanel>
    </Grid>
</Window>
