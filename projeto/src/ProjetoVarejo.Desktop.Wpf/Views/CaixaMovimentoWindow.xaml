<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.CaixaMovimentoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movimento de Caixa"
        Height="390"
        Width="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card3DStyle}" Padding="16">
            <StackPanel>
                <TextBlock x:Name="LblTitulo"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />
                <TextBlock x:Name="LblSub"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource TextSoft}" />
                <TextBlock Margin="0,12,0,4" Text="Valor" FontWeight="SemiBold" />
                <TextBox x:Name="TxtValor"
                         Height="40"
                         VerticalContentAlignment="Center"
                         Padding="10,0" />
                <TextBlock Margin="0,12,0,4" Text="Motivo" FontWeight="SemiBold" />
                <TextBox x:Name="TxtMotivo"
                         Height="90"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Padding="10,8" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Height="38" Margin="0,0,10,0" Click="Cancelar_Click" />
            <Button x:Name="BtnConfirmar" Content="Confirmar" Width="120" Height="38" Background="{StaticResource Primary}" Foreground="White" BorderThickness="0" Click="Confirmar_Click" />
        </StackPanel>
    </Grid>
</Window>
