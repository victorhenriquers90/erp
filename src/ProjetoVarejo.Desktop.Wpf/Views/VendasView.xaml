<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.VendasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="PDV / Vendas" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="{Binding CaixaStatus}" Style="{StaticResource SectionSubtitleStyle}"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Command="{Binding CarregarCommand}" Height="40"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Atualizar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NovaVendaCommand}" Height="40"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Add24" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Nova venda" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Painel PDV -->
            <Border Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Status da venda -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Venda" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AppTextMediumBrush}"/>
                            <TextBlock Text="{Binding NumeroVendaAtual}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Status" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AppTextMediumBrush}"/>
                            <TextBlock Text="{Binding StatusVendaAtual}" FontSize="15" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Total" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AppTextMediumBrush}"/>
                            <TextBlock Text="{Binding TotalVenda, StringFormat=C2}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AppPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Busca de produto -->
                    <Border Grid.Row="1" Padding="12" Style="{StaticResource CardStyle}"
                            Background="#FAFAFA" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Height="38"
                                        Text="{Binding FiltroProduto, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Codigo, barras ou descricao"/>
                            <ui:TextBox Grid.Column="1" Margin="8,0,0,0" Height="38"
                                        Text="{Binding Quantidade, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Qtd"/>
                            <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding PesquisarProdutosCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Height="38">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Search24" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBlock Text="Buscar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3" Margin="8,0,0,0" Command="{Binding AdicionarItemCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Height="38">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="15" VerticalAlignment="Center"/>
                                    <TextBlock Text="Adicionar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Produtos pesquisa + Itens venda -->
                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource CardStyle}" Padding="0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Produtos encontrados"
                                           Margin="12,10,12,8" FontWeight="SemiBold" FontSize="13"/>
                                <DataGrid ItemsSource="{Binding ProdutosPesquisa}" SelectedItem="{Binding ProdutoSelecionado}"
                                          Style="{StaticResource Win11DataGridStyle}"
                                          IsReadOnly="True" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Codigo"   Binding="{Binding Codigo}"                     Width="95"/>
                                        <DataGridTextColumn Header="Descricao" Binding="{Binding Descricao}"                 Width="*"/>
                                        <DataGridTextColumn Header="Preco"     Binding="{Binding PrecoVenda, StringFormat=C2}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="12,10,12,8">
                                    <TextBlock Text="Itens da venda" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" Command="{Binding RemoverItemCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}" Height="32">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Remover" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding ItensVenda}" SelectedItem="{Binding ItemSelecionado}"
                                          Style="{StaticResource Win11DataGridStyle}"
                                          IsReadOnly="True" BorderThickness="0" Background="Transparent">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Codigo"  Binding="{Binding Produto.Codigo}"            Width="90"/>
                                        <DataGridTextColumn Header="Produto" Binding="{Binding Produto.Descricao}"         Width="*"/>
                                        <DataGridTextColumn Header="Qtd"     Binding="{Binding Quantidade, StringFormat=N3}" Width="90"/>
                                        <DataGridTextColumn Header="Unit."   Binding="{Binding PrecoUnitario, StringFormat=C2}" Width="95"/>
                                        <DataGridTextColumn Header="Total"   Binding="{Binding Total, StringFormat=C2}"    Width="95"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- Ações de finalização -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <ui:TextBox Grid.Column="0" Height="40"
                                    Text="{Binding Desconto, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Desconto (R$)"/>

                        <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding AplicarDescontoCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Tag24" FontSize="15" VerticalAlignment="Center"/>
                                <TextBlock Text="Aplicar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <ComboBox Grid.Column="2" Margin="8,0,0,0" Height="40"
                                  Style="{StaticResource Win11ComboBoxStyle}"
                                  ItemsSource="{Binding FormasPagamento}"
                                  SelectedItem="{Binding FormaPagamentoSelecionada}"/>

                        <ui:TextBox Grid.Column="3" Margin="8,0,0,0" Height="40"
                                    Text="{Binding ValorPagamento, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Valor pago"/>

                        <Button Grid.Column="4" Margin="8,0,0,0" Command="{Binding CancelarVendaCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="15" VerticalAlignment="Center"/>
                                <TextBlock Text="Cancelar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="5" Margin="8,0,0,0" Command="{Binding FinalizarCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Height="40">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="15" VerticalAlignment="Center"/>
                                <TextBlock Text="Finalizar" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Histórico -->
            <Border Grid.Column="2" Grid.RowSpan="2" Style="{StaticResource CardStyle}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Historico recente" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Total}" Margin="0,2,0,0" Foreground="{StaticResource AppTextMediumBrush}" FontSize="12"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Vendas}" SelectedItem="{Binding VendaSelecionada}"
                              Style="{StaticResource Win11DataGridStyle}"
                              IsReadOnly="True" BorderThickness="0" Background="Transparent"
                              MouseDoubleClick="HistoricoVendasDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Numero" Binding="{Binding Numero}"                             Width="112"/>
                            <DataGridTextColumn Header="Data"   Binding="{Binding DataVenda, StringFormat=dd/MM HH:mm}" Width="108"/>
                            <DataGridTextColumn Header="Total"  Binding="{Binding Total, StringFormat=C2}"             Width="98"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}"                             Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Mensagens -->
            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Bottom">
                <TextBlock Text="{Binding Mensagem}" Foreground="#18794E" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Erro}"     Foreground="{StaticResource AppErrorBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Troco, StringFormat=Troco: {0:C2}}" Margin="0,6,0,0" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
