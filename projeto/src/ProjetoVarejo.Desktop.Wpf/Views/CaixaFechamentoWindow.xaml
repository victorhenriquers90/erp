<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.CaixaFechamentoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fechamento de Caixa"
        Height="600"
        Width="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card3DStyle}" Padding="16">
            <StackPanel>
                <TextBlock Text="Fechamento de caixa"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />
                <TextBlock Margin="0,8,0,0"
                           Text="Confira os totais calculados e informe o valor contado em dinheiro."
                           Foreground="{StaticResource TextSoft}" />

                <TextBlock Margin="0,14,0,0"
                           x:Name="LblResumo"
                           FontFamily="Consolas"
                           FontSize="14"
                           TextWrapping="Wrap" />
                <Button Margin="0,8,0,0"
                        Width="150"
                        Height="34"
                        HorizontalAlignment="Right"
                        Content="Copiar resumo"
                        Click="CopiarResumo_Click" />

                <TextBlock Margin="0,14,0,4" Text="Valor informado" FontWeight="SemiBold" />
                <TextBox x:Name="TxtValorInformado"
                         Height="40"
                         VerticalContentAlignment="Center"
                         Padding="10,0" />

                <TextBlock Margin="0,12,0,4" Text="Observação" FontWeight="SemiBold" />
                <TextBox x:Name="TxtObservacao"
                         Height="90"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Padding="10,8" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Height="38" Margin="0,0,10,0" Click="Cancelar_Click" />
            <Button x:Name="BtnConfirmar" Content="Fechar caixa" Width="140" Height="38" Background="#D64545" Foreground="White" BorderThickness="0" Click="Confirmar_Click" />
        </StackPanel>
    </Grid>
</Window>
