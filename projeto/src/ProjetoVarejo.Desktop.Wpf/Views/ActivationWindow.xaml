<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ativação do Projeto ERP"
        Height="560"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgCard}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Background="{StaticResource BrandGradient}" Padding="28,24">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" Background="{StaticResource Primary}" CornerRadius="10">
                    <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Ativação necessária" Foreground="White" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Este sistema precisa de uma licença para ser usado nesta máquina."
                               Foreground="#A9C3E0" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="28,24">
            <TextBlock Text="1. Envie o código desta máquina ao fornecedor:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}" />
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgInput}" Height="44">
                    <TextBox x:Name="TxtFingerprint" BorderThickness="0" Background="Transparent" IsReadOnly="True"
                             VerticalContentAlignment="Center" Margin="12,0" FontSize="15" FontWeight="SemiBold"
                             FontFamily="Consolas" Foreground="{StaticResource Primary}" />
                </Border>
                <Button Grid.Column="1" Content="Copiar" Width="100" Height="44" Margin="10,0,0,0" Click="Copiar_Click" />
            </Grid>

            <TextBlock Text="2. Cole aqui a chave de licença recebida:" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextStrong}" Margin="0,22,0,0" />
            <Border BorderBrush="{StaticResource StrokeSoft}" BorderThickness="1" CornerRadius="8" Background="{StaticResource BgInput}" Margin="0,8,0,0">
                <TextBox x:Name="TxtChave" BorderThickness="0" Background="Transparent" Height="110"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         Padding="12" FontSize="12" FontFamily="Consolas" />
            </Border>

            <Border x:Name="ErroBox" Margin="0,14,0,0" Background="#FEF2F2" BorderBrush="#FCA5A5"
                    BorderThickness="1" CornerRadius="8" Padding="12" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Foreground="#B42318" FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0" />
                    <TextBlock x:Name="LblErro" Foreground="#B42318" FontSize="12" TextWrapping="Wrap" MaxWidth="500" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Sair" Width="110" Height="44" Margin="0,0,10,0" Click="Sair_Click" />
                <Button x:Name="BtnAtivar" Content="Ativar" Width="160" Height="44"
                        Style="{StaticResource PrimaryButtonStyle}" Click="Ativar_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
