<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.RelatoriosWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="RelatÃ³rios gerenciais"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextStrong}" />
            <TextBlock Margin="0,8,0,0"
                       Text="AnÃ¡lises de vendas, produtos e fluxo de caixa."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,12"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="De" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtDe" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="AtÃ©" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtAte" Width="140" />
                </StackPanel>
                <Button Grid.Column="2"
                        Margin="12,20,0,0"
                        Width="110"
                        Height="36"
                        Content="Atualizar"
                        Click="Atualizar_Click" />
                <Button Grid.Column="4"
                        Margin="10,20,0,0"
                        Width="210"
                        Height="36"
                        Content="Exportar CSV (aba atual)"
                        Click="Exportar_Click" />
                <Button Grid.Column="5"
                        Margin="10,20,0,0"
                        Width="170"
                        Height="36"
                        Content="Detalhes tecnicos"
                        Click="DetalhesTecnicos_Click" />
            </Grid>
        </Border>

        <TabControl Grid.Row="2" x:Name="TabsRelatorios">
            <TabItem Header="Vendas por dia">
                <DataGrid x:Name="DgDia" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dia" Binding="{Binding Dia}" Width="2*" />
                        <DataGridTextColumn Header="Qtd Vendas" Binding="{Binding Quantidade}" Width="1.4*" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.8*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Por forma de pagamento">
                <DataGrid x:Name="DgForma" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Forma" Binding="{Binding Forma}" Width="2*" />
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Qtd}" Width="1*" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.8*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Por vendedor">
                <DataGrid x:Name="DgVendedor" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vendedor" Binding="{Binding Vendedor}" Width="2.4*" />
                        <DataGridTextColumn Header="Qtd Vendas" Binding="{Binding Qtd}" Width="1.2*" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.6*" />
                        <DataGridTextColumn Header="Ticket MÃ©dio" Binding="{Binding Ticket}" Width="1.6*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Curva ABC">
                <DataGrid x:Name="DgAbc" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CÃ³digo" Binding="{Binding Codigo}" Width="1.2*" />
                        <DataGridTextColumn Header="DescriÃ§Ã£o" Binding="{Binding Descricao}" Width="3*" />
                        <DataGridTextColumn Header="Quantidade" Binding="{Binding Quantidade}" Width="1.4*" />
                        <DataGridTextColumn Header="Faturamento" Binding="{Binding Faturamento}" Width="1.8*" />
                        <DataGridTextColumn Header="Classe" Binding="{Binding Classe}" Width="1*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Top produtos">
                <DataGrid x:Name="DgTop" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CÃ³digo" Binding="{Binding Codigo}" Width="1.2*" />
                        <DataGridTextColumn Header="DescriÃ§Ã£o" Binding="{Binding Descricao}" Width="3*" />
                        <DataGridTextColumn Header="Quantidade" Binding="{Binding Quantidade}" Width="1.4*" />
                        <DataGridTextColumn Header="Faturamento" Binding="{Binding Faturamento}" Width="1.8*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Fluxo de caixa">
                <DataGrid x:Name="DgFluxo" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dia" Binding="{Binding Dia}" Width="1.8*" />
                        <DataGridTextColumn Header="Entradas" Binding="{Binding Entradas}" Width="1.8*" />
                        <DataGridTextColumn Header="SaÃ­das" Binding="{Binding Saidas}" Width="1.8*" />
                        <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo}" Width="1.8*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Background="#FFF4ECDD"
                BorderBrush="#FFE0C18D"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
            <TextBlock x:Name="LblResumo"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextStrong}" />
        </Border>
    </Grid>
</UserControl>
