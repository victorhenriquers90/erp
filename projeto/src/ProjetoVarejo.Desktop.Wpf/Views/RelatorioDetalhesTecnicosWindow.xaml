<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.RelatorioDetalhesTecnicosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Relatorios - Detalhes Tecnicos"
        Height="760"
        Width="1060"
        MinHeight="620"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Detalhes tecnicos do relatorio"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextStrong}" />
            <TextBlock x:Name="TxtContexto"
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,12,0,10"
                Style="{StaticResource Card3DStyle}"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Aba ativa:" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock x:Name="TxtAba" Grid.Column="1" />
                <TextBlock Grid.Column="2" Text="Periodo:" FontWeight="SemiBold" Margin="16,0,8,0" />
                <TextBlock x:Name="TxtPeriodo" Grid.Column="3" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource Card3DStyle}"
                Padding="10">
            <TabControl>
                <TabItem Header="Resumo">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel LastChildFill="False" Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       Text="Resumo consolidado"
                                       FontWeight="SemiBold" />
                            <Button DockPanel.Dock="Right"
                                    Width="130"
                                    Height="34"
                                    Content="Copiar resumo"
                                    Click="CopiarResumo_Click" />
                        </DockPanel>
                        <TextBox x:Name="TxtResumo"
                                 Grid.Row="1"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True" />
                    </Grid>
                </TabItem>

                <TabItem Header="CSV">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel LastChildFill="False" Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       Text="Conteudo CSV da aba atual"
                                       FontWeight="SemiBold" />
                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="34"
                                    Content="Copiar CSV"
                                    Click="CopiarCsv_Click" />
                        </DockPanel>
                        <TextBox x:Name="TxtCsv"
                                 Grid.Row="1"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="3"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="110"
                    Height="36"
                    Content="Fechar"
                    Click="Fechar_Click" />
        </StackPanel>
    </Grid>
</Window>
