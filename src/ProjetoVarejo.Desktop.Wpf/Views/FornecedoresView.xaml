<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.FornecedoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Fornecedores" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Buscar por razao social, fantasia ou CNPJ"
                        Height="42"
                        Margin="0,0,12,0"/>
            <Button Grid.Column="1" Command="{Binding CarregarCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Height="42" Padding="18,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Search24" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="Buscar" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Fornecedores}" SelectedItem="{Binding FornecedorSelecionado}"
                      Style="{StaticResource Win11DataGridStyle}"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Razao Social" Binding="{Binding RazaoSocial}"  Width="*" MinWidth="220"/>
                    <DataGridTextColumn Header="Fantasia"     Binding="{Binding NomeFantasia}" Width="180"/>
                    <DataGridTextColumn Header="CNPJ"         Binding="{Binding Cnpj}"         Width="150"/>
                    <DataGridTextColumn Header="Telefone"     Binding="{Binding Telefone}"      Width="130"/>
                    <DataGridTextColumn Header="Email"        Binding="{Binding Email}"         Width="220"/>
                    <DataGridCheckBoxColumn Header="Ativo"    Binding="{Binding Ativo}"         Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
