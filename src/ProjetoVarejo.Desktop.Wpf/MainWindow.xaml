<Window x:Class="ProjetoVarejo.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:ProjetoVarejo.Desktop.Wpf.ViewModels"
        xmlns:views="clr-namespace:ProjetoVarejo.Desktop.Wpf.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ProjetoVarejo ERP"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI">

    <!-- DataTemplate routing: ViewModel → View -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
            <views:ClientesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProdutosViewModel}">
            <views:ProdutosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FornecedoresViewModel}">
            <views:FornecedoresView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EstoqueViewModel}">
            <views:EstoqueView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinanceiroViewModel}">
            <views:FinanceiroView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VendasViewModel}">
            <views:VendasView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CaixaViewModel}">
            <views:CaixaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsuariosViewModel}">
            <views:UsuariosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FiliaisViewModel}">
            <views:FiliaisView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
            <views:RelatoriosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditoriaViewModel}">
            <views:AuditoriaView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FiscalViewModel}">
            <views:FiscalView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OperacoesViewModel}">
            <views:OperacoesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdministracaoSistemaViewModel}">
            <views:AdministracaoSistemaView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="240" x:Name="ColSidebar"/>
            <!-- Conteúdo -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource AppSidebarBrush}">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏪" FontSize="28" VerticalAlignment="Center"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="ProjetoVarejo"
                                       Foreground="White"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="ERP"
                                       Foreground="#6A8BA0"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Separator DockPanel.Dock="Top" Background="#1E2E3E" Margin="0,0,0,8"/>

                <!-- Rodapé usuário -->
                <Border DockPanel.Dock="Bottom" Padding="16,12" Background="#0D1824">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="AccountCircle"
                                     Width="32" Height="32"
                                     Foreground="#F0A830"
                                     VerticalAlignment="Center"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="{Binding NomeUsuario}"
                                       Foreground="White"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Empresa}"
                                       Foreground="#6A8BA0"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Menu de navegação -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8,4">

                        <!-- PRINCIPAL -->
                        <TextBlock Text="PRINCIPAL"
                                   Foreground="#4A6070"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="12,8,0,4"/>

                        <Button Content="Painel" Tag="md:PackIcon Kind=ViewDashboard"
                                Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirDashboardCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="Painel" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <!-- CADASTROS -->
                        <TextBlock Text="CADASTROS"
                                   Foreground="#4A6070"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="12,16,0,4"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirClientesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountGroup" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Clientes" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirProdutosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Package" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Produtos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFornecedoresCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Truck" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Fornecedores" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFiliaisCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Store" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Filiais" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- VENDAS -->
                        <TextBlock Text="VENDAS"
                                   Foreground="#4A6070"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="12,16,0,4"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirVendasCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CartOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="PDV" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirCaixaCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Cash" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Caixa" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFiscalCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ReceiptTextCheck" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Fiscal e pagamentos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- OPERACAO -->
                        <TextBlock Text="OPERACAO"
                                   Foreground="#4A6070"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="12,16,0,4"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirEstoqueCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Warehouse" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Estoque" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirFinanceiroCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Finance" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Financeiro" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirRelatoriosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ChartBox" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Relatorios" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirOperacoesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="StoreClockOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Rotinas da loja" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ADMINISTRACAO -->
                        <TextBlock Text="ADMINISTRACAO"
                                   Foreground="#4A6070"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="12,16,0,4"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirUsuariosCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountCog" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Usuarios" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirAuditoriaCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ClipboardTextClock" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Auditoria" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding AbrirAdministracaoSistemaCommand}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CogOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Sistema" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══ CONTEÚDO PRINCIPAL ═══════════════════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- Topbar -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource AppSidebarBrush}"
                    Height="56" Padding="20,0">
                <Grid>
                    <TextBlock Text="{Binding PaginaTitulo}"
                               Foreground="White"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding NomeUsuario}"
                                   Foreground="#9BB5CC"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <md:PackIcon Kind="AccountCircle"
                                     Width="32" Height="32"
                                     Foreground="#F0A830"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Área de conteúdo — roteamento por DataTemplate -->
            <ContentControl Content="{Binding PaginaAtual}"
                            Margin="24"/>
        </DockPanel>
    </Grid>
</Window>
