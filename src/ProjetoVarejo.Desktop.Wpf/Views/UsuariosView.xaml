<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Usuarios" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>
        <TextBox Grid.Row="1" Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                 md:HintAssist.Hint="Buscar por nome ou login"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Height="44" Margin="0,0,0,16"/>
        <md:Card Grid.Row="2" Padding="0" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp1">
            <DataGrid ItemsSource="{Binding Usuarios}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" MinWidth="220"/>
                    <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="160"/>
                    <DataGridTextColumn Header="Perfil" Binding="{Binding Perfil}" Width="150"/>
                    <DataGridTextColumn Header="Ultimo acesso" Binding="{Binding UltimoAcesso, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>
    </Grid>
</UserControl>
