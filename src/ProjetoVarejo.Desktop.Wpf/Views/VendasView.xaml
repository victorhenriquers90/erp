<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.VendasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Command="{Binding CarregarCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" Height="40">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Refresh" Width="18" Height="18"/>
                    <TextBlock Text="Atualizar" Margin="8,0,0,0"/>
                </StackPanel>
            </Button>
            <StackPanel>
                <TextBlock Text="PDV / Vendas" Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
            </StackPanel>
        </DockPanel>
        <md:Card Grid.Row="1" Padding="0" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp1">
            <DataGrid ItemsSource="{Binding Vendas}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Numero" Binding="{Binding Numero}" Width="140"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataVenda, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nome}" Width="*" MinWidth="220"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C2}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>
    </Grid>
</UserControl>
