<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:conv="clr-namespace:ProjetoVarejo.Desktop.Wpf.Converters">

    <!-- Converters -->
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

    <!-- Botão da sidebar -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="Foreground"           Value="#9BB5CC"/>
        <Setter Property="HorizontalAlignment"  Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Height"               Value="44"/>
        <Setter Property="Padding"              Value="12,0"/>
        <Setter Property="Margin"               Value="0,2"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="md:ButtonAssist.CornerRadius" Value="8"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground"   Value="White"/>
                <Setter Property="Background"   Value="#1E2E3E"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#253545"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Cabeçalho de seção -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize"     Value="20"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Foreground"   Value="{StaticResource AppTextDarkBrush}"/>
        <Setter Property="Margin"       Value="0,0,0,4"/>
    </Style>

    <!-- Subtítulo de seção -->
    <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource AppTextMediumBrush}"/>
        <Setter Property="Margin"     Value="0,0,0,20"/>
    </Style>
</ResourceDictionary>
