<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.FinanceiroWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{DynamicResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Contas a pagar, contas a receber e quitações."
                       FontSize="14"
                       Foreground="{DynamicResource TextSoft}" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,16,0,14">
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="A RECEBER" Foreground="{DynamicResource TextSoft}" FontWeight="SemiBold" />
                    <TextBlock x:Name="LblReceber" Margin="0,8,0,0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="A PAGAR" Foreground="{DynamicResource TextSoft}" FontWeight="SemiBold" />
                    <TextBlock x:Name="LblPagar" Margin="0,8,0,0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="SALDO PREVISTO" Foreground="{DynamicResource TextSoft}" FontWeight="SemiBold" />
                    <TextBlock x:Name="LblSaldo" Margin="0,8,0,0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="MOVIMENTAÇÕES" Foreground="{DynamicResource TextSoft}" FontWeight="SemiBold" />
                    <TextBlock x:Name="LblMovimentos" Margin="0,8,0,0" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextStrong}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Style="{StaticResource Card3DStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Tipo" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbTipo" Height="36" SelectionChanged="FiltroSelecionadoMudou" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Status" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbStatus" Height="36" SelectionChanged="FiltroSelecionadoMudou" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Text="De" FontWeight="SemiBold" />
                        <DatePicker x:Name="DtDe" Width="140" SelectedDateChanged="FiltroDataMudou" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="10,0,0,0">
                        <TextBlock Text="Até" FontWeight="SemiBold" />
                        <DatePicker x:Name="DtAte" Width="140" SelectedDateChanged="FiltroDataMudou" />
                    </StackPanel>

                <Button Grid.Column="4"
                        Margin="12,20,0,0"
                        Width="110"
                        Height="36"
                        Content="Atualizar"
                        Click="Atualizar_Click" />
                <Button Grid.Column="5"
                        Margin="10,20,0,0"
                        Width="120"
                        Height="36"
                        Background="{StaticResource Primary}"
                        Foreground="White"
                        BorderThickness="0"
                        Content="Nova conta"
                        Click="NovaConta_Click" />
                <Button Grid.Column="6"
                        Margin="10,20,0,0"
                        Width="120"
                        Height="36"
                        Content="Quitar"
                        Click="Quitar_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Style="{StaticResource Card3DStyle}"
                Padding="8">
            <DataGrid x:Name="DgFinanceiro"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      MouseDoubleClick="DgFinanceiro_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="1*" />
                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="3*" />
                    <DataGridTextColumn Header="Cliente/Fornecedor" Binding="{Binding Pessoa}" Width="2.4*" />
                    <DataGridTextColumn Header="Vencimento" Binding="{Binding Vencimento}" Width="1.4*" />
                    <DataGridTextColumn Header="Valor" Binding="{Binding Valor}" Width="1.3*" />
                    <DataGridTextColumn Header="Pago" Binding="{Binding Pago}" Width="1.3*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.3*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
