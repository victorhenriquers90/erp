<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.PdvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDV"
        Height="860"
        Width="1480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid x:Name="RootGrid" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="HeaderBorder" Style="{StaticResource Card3DStyle}" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="LblTituloPdv"
                               Text="Frente de Caixa"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextStrong}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Atalhos: Enter adicionar | F2 buscar | F4 desconto | Del remover | F10 finalizar | F12 nova venda | Esc cancelar"
                               Foreground="{StaticResource TextSoft}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkModoOperador"
                              Margin="0,0,20,0"
                              VerticalAlignment="Center"
                              FontWeight="SemiBold"
                              Content="Modo Operador"
                              Checked="ModoOperador_Changed"
                              Unchecked="ModoOperador_Changed" />
                    <TextBlock x:Name="LblNumeroVenda"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextStrong}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="EntradaBorder" Grid.Row="1" Margin="0,12,0,12" Style="{StaticResource Card3DStyle}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Codigo / Codigo de barras" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtCodigo"
                             Height="40"
                             FontSize="18"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             GotFocus="TxtCodigo_GotFocus"
                             TextChanged="TxtCodigo_TextChanged"
                             KeyDown="TxtCodigo_KeyDown" />
                    <Border x:Name="SugestoesBox"
                            Margin="0,4,0,0"
                            Background="White"
                            BorderBrush="#D1D9E6"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <ListBox x:Name="LstSugestoes"
                                 BorderThickness="0"
                                 MaxHeight="220"
                                 KeyDown="LstSugestoes_KeyDown"
                                 MouseDoubleClick="LstSugestoes_MouseDoubleClick" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Quantidade" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Height="40"
                                Content="-"
                                FontSize="18"
                                Click="DiminuirQtd_Click" />
                        <TextBox x:Name="TxtQuantidade"
                                 Grid.Column="1"
                                 Margin="6,0"
                                 Height="40"
                                 FontSize="18"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Padding="10,0"
                                 GotFocus="TxtQuantidade_GotFocus"
                                 Text="1" />
                        <Button Grid.Column="2"
                                Height="40"
                                Content="+"
                                FontSize="18"
                                Click="AumentarQtd_Click" />
                    </Grid>
                </StackPanel>
                <Button Grid.Column="2"
                        Margin="10,20,0,0"
                        Width="150"
                        Height="40"
                        Content="Adicionar"
                        Background="#1F9D55"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Adicionar_Click" />
                <Button Grid.Column="3"
                        Margin="10,20,0,0"
                        Width="130"
                        Height="40"
                        Content="Buscar (F2)"
                        Click="Buscar_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ItensBorder" Style="{StaticResource Card3DStyle}" Padding="8">
                <DataGrid x:Name="DgItens"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="1.3*" />
                        <DataGridTextColumn Header="Descricao" Binding="{Binding Descricao}" Width="3.2*" />
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="1*" />
                        <DataGridTextColumn Header="Preco Unit." Binding="{Binding PrecoUnitario}" Width="1.4*" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.4*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <Border x:Name="TotalBorder" Style="{StaticResource Card3DStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="LblTotalTitulo"
                                   Text="TOTAL"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSoft}" />
                        <TextBlock x:Name="LblTotal"
                                   Margin="0,6,0,0"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextStrong}" />
                        <TextBlock x:Name="LblSubtotal" Margin="0,8,0,0" FontSize="14" />
                        <TextBlock x:Name="LblDesconto" Margin="0,4,0,0" FontSize="14" />
                        <TextBlock x:Name="LblItens" Margin="0,4,0,0" FontSize="14" />
                    </StackPanel>
                </Border>

                <Button Margin="0,12,0,0"
                        Height="54"
                        Content="Finalizar (F10)"
                        Background="#1F9D55"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Finalizar_Click" />
                <Button Margin="0,8,0,0" Height="46" Content="Desconto (F4)" Click="Desconto_Click" />
                <Button Margin="0,8,0,0" Height="46" Content="Remover item (Del)" Click="Remover_Click" />
                <Button Margin="0,8,0,0" Height="46" Content="Nova venda (F12)" Click="NovaVenda_Click" />
                <Button Margin="0,8,0,0" Height="46" Content="Cancelar venda (Esc)" Click="CancelarVenda_Click" />

                <UniformGrid Margin="0,10,0,0" Columns="4">
                    <Button Content="1" Height="38" Click="QtdPreset_Click" />
                    <Button Content="2" Height="38" Click="QtdPreset_Click" />
                    <Button Content="3" Height="38" Click="QtdPreset_Click" />
                    <Button Content="5" Height="38" Click="QtdPreset_Click" />
                </UniformGrid>

                <Border Margin="0,10,0,0" Style="{StaticResource Card3DStyle}" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Teclado touch"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSoft}" />
                        <UniformGrid Margin="0,8,0,0" Columns="4">
                            <Button Content="7" Height="42" Click="Numpad_Click" />
                            <Button Content="8" Height="42" Click="Numpad_Click" />
                            <Button Content="9" Height="42" Click="Numpad_Click" />
                            <Button Content="BK" Height="42" Click="Numpad_Click" />
                            <Button Content="4" Height="42" Click="Numpad_Click" />
                            <Button Content="5" Height="42" Click="Numpad_Click" />
                            <Button Content="6" Height="42" Click="Numpad_Click" />
                            <Button Content="CLR" Height="42" Click="Numpad_Click" />
                            <Button Content="1" Height="42" Click="Numpad_Click" />
                            <Button Content="2" Height="42" Click="Numpad_Click" />
                            <Button Content="3" Height="42" Click="Numpad_Click" />
                            <Button Content="ADD" Height="42" Click="Numpad_Click" />
                            <Button Content="0" Height="42" Click="Numpad_Click" />
                            <Button Content="00" Height="42" Click="Numpad_Click" />
                            <Button Content="," Height="42" Click="Numpad_Click" />
                            <Button Content="COD" Height="42" Click="Numpad_Click" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
