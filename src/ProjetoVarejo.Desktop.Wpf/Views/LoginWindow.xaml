<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ProjetoVarejo ERP"
        Height="620" Width="960"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Painel esquerdo — marca ────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource AppSidebarBrush}" CornerRadius="0,0,0,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <TextBlock Text="🏪"
                           FontSize="56"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="ProjetoVarejo"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Sistema de Gestão ERP"
                           Foreground="#9BB5CC"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,48"/>
                <ItemsControl>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,6">
                                <TextBlock Text="•" Foreground="#F0A830" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding}" Foreground="#9BB5CC" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.Items>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">PDV moderno · NFC-e integrado</system:String>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Controle de estoque em tempo real</system:String>
                        <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Financeiro · Relatórios · Backup</system:String>
                    </ItemsControl.Items>
                </ItemsControl>

                <TextBlock Text="v1.0.0"
                           Foreground="#4A6070"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,48,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Painel direito — formulário ───────────────────── -->
        <Grid Grid.Column="1" Margin="60,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Bem-vindo"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource AppTextDarkBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Entre com suas credenciais para continuar"
                           Foreground="{StaticResource AppTextMediumBrush}"
                           FontSize="13"
                           Margin="0,0,0,40"/>

                <!-- Login -->
                <TextBlock Text="USUÁRIO"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextMediumBrush}"
                           Margin="0,0,0,6"/>
                <md:Card UniformCornerRadius="8"
                         md:ElevationAssist.Elevation="Dp1"
                         Padding="0"
                         Margin="0,0,0,16">
                    <TextBox x:Name="TxtLogin"
                             md:HintAssist.Hint="admin"
                             md:TextFieldAssist.HasClearButton="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontSize="14"
                             BorderBrush="Transparent"
                             BorderThickness="0"
                             Padding="14,12"/>
                </md:Card>

                <!-- Senha -->
                <TextBlock Text="SENHA"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextMediumBrush}"
                           Margin="0,0,0,6"/>
                <md:Card UniformCornerRadius="8"
                         md:ElevationAssist.Elevation="Dp1"
                         Padding="0"
                         Margin="0,0,0,8">
                    <PasswordBox x:Name="TxtSenha"
                                 md:HintAssist.Hint="••••••"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 FontSize="14"
                                 BorderBrush="Transparent"
                                 BorderThickness="0"
                                 Padding="14,12"
                                 KeyDown="TxtSenha_KeyDown"/>
                </md:Card>

                <!-- Erro -->
                <TextBlock x:Name="TxtErro"
                           Foreground="{StaticResource AppErrorBrush}"
                           FontSize="12"
                           Margin="0,4,0,16"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Botão Entrar -->
                <Button x:Name="BtnEntrar"
                        Content="ENTRAR"
                        Click="BtnEntrar_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource AppPrimaryBrush}"
                        BorderBrush="{StaticResource AppPrimaryBrush}"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        Height="48"
                        md:ButtonAssist.CornerRadius="8"
                        md:ElevationAssist.Elevation="Dp2"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,0"/>

                <!-- Loading -->
                <ProgressBar x:Name="PbLoading"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             IsIndeterminate="True"
                             Margin="0,12,0,0"
                             Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
