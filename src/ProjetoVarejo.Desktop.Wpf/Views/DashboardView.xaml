<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Cabeçalho -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Painel operacional"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource AppTextDarkBrush}"/>
                <TextBlock Text="Indicadores e processos principais"
                           FontSize="13"
                           Foreground="{StaticResource AppTextMediumBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- KPI Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <!-- Vendas Hoje -->
                <md:Card Margin="0,0,12,0" Padding="20" UniformCornerRadius="12"
                         md:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="8">
                                <md:PackIcon Kind="CashMultiple" Width="22" Height="22"
                                             Foreground="{StaticResource AppPrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="VENDAS HOJE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="R$ 0,00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Nenhuma venda hoje"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </md:Card>

                <!-- Transações -->
                <md:Card Margin="0,0,12,0" Padding="20" UniformCornerRadius="12"
                         md:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#E8F5E9" CornerRadius="8" Padding="8">
                                <md:PackIcon Kind="CartOutline" Width="22" Height="22" Foreground="#258C58"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="TRANSAÇÕES"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="0"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="vendas realizadas"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </md:Card>

                <!-- Alertas Estoque -->
                <md:Card Margin="0,0,12,0" Padding="20" UniformCornerRadius="12"
                         md:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#FFF8E1" CornerRadius="8" Padding="8">
                                <md:PackIcon Kind="AlertOutline" Width="22" Height="22" Foreground="#F9A825"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="ALERTAS ESTOQUE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="0"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="produtos abaixo do mínimo"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </md:Card>

                <!-- A Pagar -->
                <md:Card Padding="20" UniformCornerRadius="12"
                         md:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#FCE4EC" CornerRadius="8" Padding="8">
                                <md:PackIcon Kind="Bank" Width="22" Height="22" Foreground="#BB2B2B"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="A PAGAR (7 DIAS)"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextMediumBrush}"/>
                        <TextBlock Text="R$ 0,00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource AppTextDarkBrush}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="contas no prazo"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </md:Card>
            </UniformGrid>

            <!-- Mapa de módulos -->
            <md:Card Padding="24" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <TextBlock Text="Acesso rápido"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AppTextDarkBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Ações frequentes do dia a dia"
                               FontSize="12"
                               Foreground="{StaticResource AppTextMediumBrush}"
                               Margin="0,0,0,20"/>
                    <WrapPanel>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,12,12" Height="48" Width="180"
                                BorderBrush="{StaticResource AppBorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CartOutline" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Nova venda" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,12,12" Height="48" Width="180"
                                BorderBrush="{StaticResource AppBorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Cash" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Abrir caixa" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,12,12" Height="48" Width="180"
                                BorderBrush="{StaticResource AppBorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Package" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Movimentar estoque" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </md:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
