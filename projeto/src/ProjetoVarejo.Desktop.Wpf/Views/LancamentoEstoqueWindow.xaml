<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.LancamentoEstoqueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lançamento de estoque"
        Height="620"
        Width="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2"
                           x:Name="LblTitulo"
                           Text="Lançamento"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />

                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0">
                    <TextBlock Text="Código ou código de barras" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCodigo"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Width="120"
                                Height="38"
                                Content="Buscar"
                                Click="Buscar_Click" />
                    </Grid>
                    <TextBlock x:Name="LblProduto"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextSoft}"
                               FontStyle="Italic"
                               Text="(nenhum produto selecionado)" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,12,8,0">
                    <TextBlock Text="Quantidade" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtQuantidade" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="1" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,12,0,0">
                    <TextBlock Text="Custo unitário (opcional)" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtCusto" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <TextBlock Text="Fornecedor (entrada)" FontWeight="SemiBold" />
                    <ComboBox x:Name="CmbFornecedor" Height="38" />
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <TextBlock Text="Documento" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtDocumento" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                </StackPanel>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <TextBlock Text="Observação" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtObservacao"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Padding="10,8" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,14,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="112"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click" />
            <Button x:Name="BtnSalvar"
                    Content="Lançar"
                    Width="130"
                    Height="40"
                    Background="{StaticResource Primary}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Salvar_Click" />
        </StackPanel>
    </Grid>
</Window>
