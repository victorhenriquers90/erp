<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projeto ERP — Configuração inicial"
        Width="640" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0F1923">

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1A2636"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CardSelected" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Background" Value="#1A3A5C"/>
            <Setter Property="BorderBrush" Value="#2A78DA"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2A78DA" Offset="0"/>
                        <GradientStop Color="#0052B4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,28">
            <TextBlock Text="Projeto ERP" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Configuração inicial da rede" FontSize="14" Foreground="#8AA3BE" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Passo 1: selecionar modo -->
        <StackPanel x:Name="PainelModo" Grid.Row="1">
            <TextBlock Text="Esta máquina é:" FontSize="13" FontWeight="SemiBold"
                       Foreground="#C8D8E8" Margin="0,0,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card Servidor -->
                <Border x:Name="CardServidor" Grid.Column="0" Style="{StaticResource Card}"
                        MouseLeftButtonUp="CardServidor_Click">
                    <StackPanel>
                        <TextBlock Text="🖥️" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Servidor" FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#8AA3BE" FontSize="12"
                                   Text="Esta máquina hospeda o banco de dados e a API. Deve ficar ligada enquanto os clientes trabalham."/>
                        <TextBlock Text="✔ SQL Server local" Foreground="#4ADE80" FontSize="11" Margin="0,12,0,2" HorizontalAlignment="Center"/>
                        <TextBlock Text="✔ API como serviço Windows" Foreground="#4ADE80" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="✔ Backup automático" Foreground="#4ADE80" FontSize="11" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Card Cliente -->
                <Border x:Name="CardCliente" Grid.Column="2" Style="{StaticResource Card}"
                        MouseLeftButtonUp="CardCliente_Click">
                    <StackPanel>
                        <TextBlock Text="💻" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cliente / Caixa" FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#8AA3BE" FontSize="12"
                                   Text="Esta máquina é um terminal de atendimento ou gestão. Precisa de rede com o servidor."/>
                        <TextBlock Text="✔ ERP / PDV / Gestão" Foreground="#4ADE80" FontSize="11" Margin="0,12,0,2" HorizontalAlignment="Center"/>
                        <TextBlock Text="✔ Conecta via API" Foreground="#4ADE80" FontSize="11" HorizontalAlignment="Center"/>
                        <TextBlock Text="✔ Sem SQL exposto" Foreground="#4ADE80" FontSize="11" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <!-- Painel de configuração (varia por modo) -->
        <StackPanel x:Name="PainelConfig" Grid.Row="2" Margin="0,16,0,0" Visibility="Collapsed">

            <!-- Config Servidor -->
            <StackPanel x:Name="ConfigServidor" Visibility="Collapsed">
                <TextBlock Text="Configuração do Servidor" FontSize="13" FontWeight="SemiBold"
                           Foreground="#C8D8E8" Margin="0,0,0,12"/>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="String de conexão SQL Server" Foreground="#8AA3BE" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtConnStr" Background="#0F1923" Foreground="White" BorderBrush="#2A3E55"
                             BorderThickness="1" Padding="10,8" FontFamily="Consolas"
                             Text="Server=.\SQLEXPRESS;Database=ProjetoVarejo;Trusted_Connection=True;TrustServerCertificate=True;Encrypt=False;"/>
                </StackPanel>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Porta da API (padrão: 5000)" Foreground="#8AA3BE" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPortaApi" Background="#0F1923" Foreground="White" BorderBrush="#2A3E55"
                             BorderThickness="1" Padding="10,8" Width="120" HorizontalAlignment="Left" Text="5000"/>
                </StackPanel>
                <TextBlock x:Name="TxtDicaServidor" TextWrapping="Wrap" FontSize="11" Foreground="#8AA3BE"
                           Text="💡 A API será registrada como serviço Windows 'ProjetoERP-Api'. Os clientes vão acessar http://[IP-desta-máquina]:5000"/>
            </StackPanel>

            <!-- Config Cliente -->
            <StackPanel x:Name="ConfigCliente" Visibility="Collapsed">
                <TextBlock Text="Localização do Servidor" FontSize="13" FontWeight="SemiBold"
                           Foreground="#C8D8E8" Margin="0,0,0,12"/>
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="URL da API do servidor (ex.: http://192.168.1.10:5000)" Foreground="#8AA3BE" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUrlApi" Background="#0F1923" Foreground="White" BorderBrush="#2A3E55"
                             BorderThickness="1" Padding="10,8" Text="http://"/>
                </StackPanel>
                <Button Content="🔍 Testar conexão" Style="{StaticResource BtnPrimary}"
                        HorizontalAlignment="Left" Margin="0,4,0,0"
                        Click="TestarConexao_Click"/>
                <TextBlock x:Name="TxtStatusConexao" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <!-- Rodapé -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtInfo" Grid.Column="0" Foreground="#4A6378" FontSize="11"
                       VerticalAlignment="Center" TextWrapping="Wrap"
                       Text="Selecione o papel desta máquina na rede para continuar."/>
            <Button x:Name="BtnConfirmar" Grid.Column="1" Content="Confirmar e iniciar →"
                    Style="{StaticResource BtnPrimary}" IsEnabled="False"
                    Click="Confirmar_Click"/>
        </Grid>
    </Grid>
</Window>
