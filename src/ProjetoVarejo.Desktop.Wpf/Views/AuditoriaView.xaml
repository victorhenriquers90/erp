<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.AuditoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Auditoria" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Registros}"
                      Style="{StaticResource Win11DataGridStyle}"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data"     Binding="{Binding Data, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="Usuario"  Binding="{Binding Usuario.Nome}"                        Width="180"/>
                    <DataGridTextColumn Header="Entidade" Binding="{Binding Entidade}"                            Width="160"/>
                    <DataGridTextColumn Header="Registro" Binding="{Binding RegistroId}"                          Width="100"/>
                    <DataGridTextColumn Header="Tipo"     Binding="{Binding Tipo}"                                Width="100"/>
                    <DataGridTextColumn Header="Depois"   Binding="{Binding ValoresDepois}"                       Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
