<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.ProdutoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Produto"
        Height="700"
        Width="980"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.ColumnSpan="2"
                               Text="Cadastro de produto"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextStrong}" />

                    <StackPanel Grid.Row="1" Margin="0,14,8,0">
                        <TextBlock Text="Código" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtCodigo" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,14,0,0">
                        <TextBlock Text="Código de barras" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtCodigoBarras" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                        <TextBlock Text="Descrição" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtDescricao" Height="38" VerticalContentAlignment="Center" Padding="10,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,10,8,0">
                        <TextBlock Text="Categoria" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbCategoria" Height="38" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Unidade" FontWeight="SemiBold" />
                        <ComboBox x:Name="CmbUnidade" Height="38" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,10,8,0">
                        <TextBlock Text="Preço custo" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtPrecoCusto" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Preço venda" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtPrecoVenda" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,00" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,10,8,0">
                        <TextBlock Text="Estoque" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtEstoque" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,000" />
                    </StackPanel>
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="8,10,0,0">
                        <TextBlock Text="Estoque mínimo" FontWeight="SemiBold" />
                        <TextBox x:Name="TxtEstoqueMinimo" Height="38" VerticalContentAlignment="Center" Padding="10,0" Text="0,000" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <CheckBox x:Name="ChkControlaEstoque"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Content="Controla estoque" />
            <CheckBox x:Name="ChkVendaFracionada"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"
                      Content="Venda fracionada" />
            <CheckBox x:Name="ChkAtivo"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Content="Produto ativo" />
            <Button Content="Cancelar"
                    Width="112"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="Cancelar_Click" />
            <Button x:Name="BtnSalvar"
                    Content="Salvar"
                    Width="130"
                    Height="40"
                    Background="{StaticResource Primary}"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Salvar_Click" />
        </StackPanel>
    </Grid>
</Window>
