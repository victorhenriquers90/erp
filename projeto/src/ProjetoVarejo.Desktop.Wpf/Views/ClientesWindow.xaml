<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.ClientesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{StaticResource BgApp}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Clientes"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextStrong}" />
            <TextBlock x:Name="LblResumo"
                       Margin="0,8,0,0"
                       Text="0 cliente(s)"
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Padding="14"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtBusca"
                         Height="40"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         TextChanged="TxtBusca_TextChanged" />
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Content="Atualizar"
                        Width="110"
                        Height="40"
                        Click="Atualizar_Click" />
                <Button Grid.Column="2"
                        Margin="10,0,0,0"
                        Content="Novo"
                        Width="100"
                        Height="40"
                        Background="{StaticResource Primary}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Novo_Click" />
                <Button Grid.Column="3"
                        Margin="10,0,0,0"
                        Content="Editar"
                        Width="100"
                        Height="40"
                        Click="Editar_Click" />
                <Button Grid.Column="4"
                        Margin="10,0,0,0"
                        Content="Excluir"
                        Width="100"
                        Height="40"
                        Click="Excluir_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource StrokeSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="8">
            <DataGrid x:Name="DgClientes"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="3*" />
                    <DataGridTextColumn Header="CPF/CNPJ" Binding="{Binding CpfCnpj}" Width="2*" />
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="2*" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="3*" />
                    <DataGridTextColumn Header="Cidade" Binding="{Binding CidadeUf}" Width="2*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.3*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
