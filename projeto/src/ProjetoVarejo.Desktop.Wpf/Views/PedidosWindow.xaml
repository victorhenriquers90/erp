<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.PedidosWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{DynamicResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Acompanhamento de pedidos com base nas vendas do ERP."
                       FontSize="14"
                       Foreground="{DynamicResource TextSoft}" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,16,0,12">
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Total de pedidos" Foreground="{DynamicResource TextSoft}" />
                    <TextBlock x:Name="LblTotalPedidos" Margin="0,6,0,0" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Finalizados" Foreground="{DynamicResource TextSoft}" />
                    <TextBlock x:Name="LblFinalizados" Margin="0,6,0,0" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,12,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Em aberto" Foreground="{DynamicResource TextSoft}" />
                    <TextBlock x:Name="LblEmAberto" Margin="0,6,0,0" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card3DStyle}" Padding="12">
                <StackPanel>
                    <TextBlock Text="Valor no período" Foreground="{DynamicResource TextSoft}" />
                    <TextBlock x:Name="LblValorPeriodo" Margin="0,6,0,0" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource Card3DStyle}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="De" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtDe" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Até" FontWeight="SemiBold" />
                    <DatePicker x:Name="DtAte" Width="140" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Cliente / Número" FontWeight="SemiBold" />
                    <TextBox x:Name="TxtBusca" Height="36" VerticalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="10,0,0,0">
                    <TextBlock Text="Status" FontWeight="SemiBold" />
                    <ComboBox x:Name="CmbStatus" Height="36" SelectedIndex="0">
                        <ComboBoxItem Content="Todos" />
                        <ComboBoxItem Content="Em aberto" />
                        <ComboBoxItem Content="Finalizada" />
                        <ComboBoxItem Content="Cancelada" />
                    </ComboBox>
                </StackPanel>
                <Button Grid.Column="4"
                        Margin="12,20,0,0"
                        Width="120"
                        Height="36"
                        Content="Filtrar"
                        Click="Filtrar_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card3DStyle}" Padding="8">
            <DataGrid x:Name="DgPedidos" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Número" Binding="{Binding Numero}" Width="1.2*" />
                    <DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="1.4*" />
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" Width="2.6*" />
                    <DataGridTextColumn Header="Vendedor" Binding="{Binding Vendedor}" Width="2*" />
                    <DataGridTextColumn Header="Itens" Binding="{Binding Itens}" Width="0.8*" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="1.2*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.2*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
