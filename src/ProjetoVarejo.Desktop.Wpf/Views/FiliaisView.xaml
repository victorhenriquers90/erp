<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.FiliaisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Filiais" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>
        <md:Card Grid.Row="1" Padding="0" UniformCornerRadius="12" md:ElevationAssist.Elevation="Dp1">
            <DataGrid ItemsSource="{Binding Filiais}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Codigo" Binding="{Binding Codigo}" Width="100"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*" MinWidth="220"/>
                    <DataGridTextColumn Header="CNPJ" Binding="{Binding Cnpj}" Width="150"/>
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="130"/>
                    <DataGridCheckBoxColumn Header="Matriz" Binding="{Binding IsMatriz}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Ativa" Binding="{Binding Ativo}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>
    </Grid>
</UserControl>
