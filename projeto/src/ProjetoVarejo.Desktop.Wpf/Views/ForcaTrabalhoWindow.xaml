<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.ForcaTrabalhoWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource BgApp}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Visão de equipe, perfis de acesso e produtividade operacional."
                       FontSize="14"
                       Foreground="{StaticResource TextSoft}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Colaboradores ativos" Foreground="{StaticResource TextSoft}" />
                    <TextBlock x:Name="LblAtivos" Margin="0,6,0,0" FontSize="26" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Gestores" Foreground="{StaticResource TextSoft}" />
                    <TextBlock x:Name="LblGestores" Margin="0,6,0,0" FontSize="26" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Vendas 30 dias" Foreground="{StaticResource TextSoft}" />
                    <TextBlock x:Name="LblVendas30" Margin="0,6,0,0" FontSize="26" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card3DStyle}" Margin="0,0,10,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Faturamento 30 dias" Foreground="{StaticResource TextSoft}" />
                    <TextBlock x:Name="LblFaturamento30" Margin="0,6,0,0" FontSize="26" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Button Grid.Column="4"
                    Width="120"
                    Height="36"
                    Margin="0,16,0,0"
                    Content="Atualizar"
                    Click="Atualizar_Click" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card3DStyle}" Padding="8">
            <DataGrid x:Name="DgEquipe" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2.2*" />
                    <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="1.4*" />
                    <DataGridTextColumn Header="Perfil" Binding="{Binding Perfil}" Width="1.4*" />
                    <DataGridTextColumn Header="Último acesso" Binding="{Binding UltimoAcesso}" Width="1.6*" />
                    <DataGridTextColumn Header="Vendas (30d)" Binding="{Binding Vendas}" Width="1*" />
                    <DataGridTextColumn Header="Faturamento (30d)" Binding="{Binding Faturamento}" Width="1.4*" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
