<Window x:Class="ProjetoVarejo.Desktop.Wpf.Views.CaixaAberturaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abrir Caixa"
        Height="290"
        Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgApp}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card3DStyle}" Padding="16">
            <StackPanel>
                <TextBlock Text="Abrir caixa"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextStrong}" />
                <TextBlock Margin="0,8,0,0"
                           Text="Informe o valor inicial no caixa."
                           Foreground="{StaticResource TextSoft}" />
                <TextBox x:Name="TxtValor"
                         Margin="0,14,0,0"
                         Height="40"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         Text="0,00" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Width="100" Height="38" Margin="0,0,10,0" Click="Cancelar_Click" />
            <Button x:Name="BtnConfirmar" Content="Abrir" Width="120" Height="38" Background="#1F9D55" Foreground="White" BorderThickness="0" Click="Confirmar_Click" />
        </StackPanel>
    </Grid>
</Window>
