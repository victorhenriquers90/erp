@namespace ProjetoVarejo.Web.Shared.Components

<div class="alert-container" style="display: @(Visible ? "block" : "none")">
    <div class="alert alert-@TypeClass">
        <div class="alert-icon">
            @switch (Type)
            {
                case AlertType.Success:
                    <span>✓</span>
                    break;
                case AlertType.Error:
                    <span>✕</span>
                    break;
                case AlertType.Warning:
                    <span>!</span>
                    break;
                case AlertType.Info:
                    <span>ⓘ</span>
                    break;
            }
        </div>
        <div class="alert-content">
            <div class="alert-title">@Title</div>
            @if (!string.IsNullOrEmpty(Message))
            {
                <div class="alert-message">@Message</div>
            }
        </div>
        @if (Dismissible)
        {
            <button class="alert-close" @onclick="Dismiss">×</button>
        }
    </div>
</div>

<style>
    .alert-container {
        margin-bottom: 16px;
        animation: slideIn 0.3s ease-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .alert {
        display: flex;
        align-items: flex-start;
        padding: 16px;
        border-radius: 8px;
        gap: 12px;
        font-family: "Segoe UI", sans-serif;
    }

    .alert-icon {
        font-size: 20px;
        font-weight: bold;
        margin-top: 2px;
        min-width: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .alert-content {
        flex: 1;
    }

    .alert-title {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 4px;
    }

    .alert-message {
        font-size: 13px;
        opacity: 0.9;
    }

    .alert-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        padding: 0;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .alert-close:hover {
        opacity: 1;
    }

    .alert-success {
        background-color: #e8f5e9;
        color: #2e7d32;
        border-left: 4px solid #4caf50;
    }

    .alert-error {
        background-color: #ffebee;
        color: #c62828;
        border-left: 4px solid #f44336;
    }

    .alert-warning {
        background-color: #fff3e0;
        color: #e65100;
        border-left: 4px solid #ff9800;
    }

    .alert-info {
        background-color: #e3f2fd;
        color: #1565c0;
        border-left: 4px solid #2196f3;
    }
</style>

@code {
    public enum AlertType { Success, Error, Warning, Info }

    [Parameter] public AlertType Type { get; set; } = AlertType.Info;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public bool Dismissible { get; set; } = true;
    [Parameter] public bool Visible { get; set; } = true;
    [Parameter] public EventCallback OnDismiss { get; set; }

    private string TypeClass => Type switch
    {
        AlertType.Success => "success",
        AlertType.Error => "error",
        AlertType.Warning => "warning",
        _ => "info"
    };

    private async Task Dismiss()
    {
        Visible = false;
        await OnDismiss.InvokeAsync();
    }
}
