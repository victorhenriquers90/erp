<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.FiliaisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Filiais" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Filiais}"
                      Style="{StaticResource Win11DataGridStyle}"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Codigo"   Binding="{Binding Codigo}"   Width="100"/>
                    <DataGridTextColumn Header="Nome"     Binding="{Binding Nome}"     Width="*" MinWidth="220"/>
                    <DataGridTextColumn Header="CNPJ"     Binding="{Binding Cnpj}"     Width="150"/>
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="130"/>
                    <DataGridCheckBoxColumn Header="Matriz" Binding="{Binding IsMatriz}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Ativa"  Binding="{Binding Ativo}"    Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
