<UserControl x:Class="ProjetoVarejo.Desktop.Wpf.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CarregarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Usuarios" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding Total}" Style="{StaticResource SectionSubtitleStyle}"/>
        </StackPanel>

        <ui:TextBox Grid.Row="1"
                    Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Buscar por nome ou login"
                    Height="42" Margin="0,0,0,16"/>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Usuarios}"
                      Style="{StaticResource Win11DataGridStyle}"
                      IsReadOnly="True" BorderThickness="0" Background="Transparent">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome"          Binding="{Binding Nome}"                                          Width="*" MinWidth="220"/>
                    <DataGridTextColumn Header="Login"         Binding="{Binding Login}"                                         Width="160"/>
                    <DataGridTextColumn Header="Perfil"        Binding="{Binding Perfil}"                                        Width="150"/>
                    <DataGridTextColumn Header="Ultimo acesso" Binding="{Binding UltimoAcesso, StringFormat=dd/MM/yyyy HH:mm}"   Width="160"/>
                    <DataGridCheckBoxColumn Header="Ativo"     Binding="{Binding Ativo}"                                         Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
